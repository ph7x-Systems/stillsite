[site]
name = "{{ project_name }}"
base_url = "{{ base_url }}"
languages = [{% for lang in languages.replace(' ', '').split(',') %}"{{ lang }}"{% if not loop.last %}, {% endif %}{% endfor %}]
blog_path = "blog"
theme = "{{ theme }}"

[storage]
url = "sqlite:///content.sqlite3"

[build]
output = "_site"
