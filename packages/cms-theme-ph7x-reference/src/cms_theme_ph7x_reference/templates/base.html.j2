<!DOCTYPE html>
<html lang="{{ head.language.value }}"{% if head.direction == "rtl" %} dir="rtl"{% endif %}>
<head>
{% include "_head.html.j2" %}
{% block styles %}
<link rel="stylesheet" href="{{ asset_urls['assets/blog.css'] }}">
<link rel="stylesheet" href="{{ asset_urls['assets/site.css'] }}">
{% endblock %}
<link rel="stylesheet" href="{{ asset_urls['assets/utils.css'] }}">
<link rel="stylesheet" href="{{ asset_urls['assets/sardine.css'] }}">
<link rel="icon" type="image/svg+xml" href="{{ asset_urls['assets/favicon.svg'] }}">
<link rel="preload" as="font" type="font/woff2" crossorigin href="{{ asset_urls['assets/fonts/inter-normal-latin.woff2'] }}">
<link rel="preload" as="font" type="font/woff2" crossorigin href="{{ asset_urls['assets/fonts/newsreader-normal-latin.woff2'] }}">
<script type="speculationrules">
{"prerender": [{"where": {"href_matches": "/*"}, "eagerness": "moderate"}]}
</script>
</head>
<body>
<div class="grain" aria-hidden="true"></div>
{% block backdrop %}{% endblock %}
<header id="hdr">
  <div class="wrap nav">
    <a href="{{ nav.home_url }}" class="brand"><span class="wm">{{ head.site_name }}</span></a>
    <nav class="lk">
      {% for entry in nav.menu %}<a href="{{ entry.url }}">{{ entry.label }}</a>{% endfor %}
    </nav>
    <div class="lang">
      {% for entry in nav.languages %}<a{% if entry.current %} class="on" aria-current="true"{% endif %} href="{{ entry.url }}">{{ entry.code | upper }}</a>{% endfor %}
    </div>
  </div>
</header>
<main id="main">
{% block main %}{% endblock %}
</main>
{# Back to top — a plain anchor (the "#top" fragment is a native scroll-to-top);
   it fades in through a scroll-driven animation, no JavaScript (ADR-0010). #}
<a class="top" href="#top" aria-label="{{ nav.top_label | default("Back to top") }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg></a>
<footer>
  <div class="wrap">
    <div class="fg">
      <span>{{ footer.text }}</span>
      <nav class="fl">
        {% for entry in footer.menu %}<a href="{{ entry.url }}">{{ entry.label }}</a>{% endfor %}
        {% if footer.admin_url %}<a class="fl-adm" href="{{ footer.admin_url }}" rel="nofollow">{{ footer.admin_label }}</a>{% endif %}
      </nav>
    </div>
  </div>
</footer>
</body>
</html>
