{% extends "base.html.j2" %}
{% block main %}
{% set hero_sections = sections | selectattr("kind", "equalto", "hero") | list %}
{% if not hero_sections %}
<div class="wrap page">
  <h1 class="page-title">{{ page.title }}</h1>
  {% if page.description %}<p class="lead">{{ page.description }}</p>{% endif %}
  {% if page.body_html %}<div class="page-body">{{ page.body_html }}</div>{% endif %}
</div>
{% endif %}
{% for section in sections %}
{% if section.kind == "hero" %}
<section class="hero" id="{{ section.key }}">
  <div class="aurora" aria-hidden="true"><span class="a1"></span><span class="a2"></span></div>
  <div class="wrap">
    <div class="hero-top">
      {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
      {% if section.data.lead %}<p class="lead-line">{{ section.data.lead }}</p>{% endif %}
    </div>
    <h1>{{ section.data.heading }}{% if section.data.accent %} <span class="it">{{ section.data.accent }}</span>{% endif %}</h1>
    <div class="base">
      <p>{{ page.description }}</p>
      {# Two calls to action like the original: the primary first, one secondary. #}
      <div class="cta">
        {% for entry in nav.menu[:2] %}
        <a href="{{ entry.url }}" class="btn{% if loop.first %} btn-p{% endif %}">{{ entry.label }}</a>
        {% endfor %}
      </div>
    </div>
    {% for image in section.images %}
    <picture>{% for source in image.sources %}<source type="{{ source.type }}" srcset="{{ source.srcset }}" sizes="100vw">{% endfor %}<img class="hero-art" src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="100vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}"></picture>
    {% endfor %}
  </div>
</section>
{% elif section.kind == "latest-articles" %}
<section class="sec latest" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
    <h2>{{ section.data.heading }}</h2>
    <div class="b-grid">
    {% for entry in latest %}
      <a class="b-card" href="{{ entry.url }}">
        {% if entry.thumb %}
        <div class="b-thumb"><picture>{% for source in entry.thumb.sources %}<source type="{{ source.type }}" srcset="{{ source.srcset }}" sizes="(max-width: 820px) 100vw, 33vw">{% endfor %}<img src="{{ entry.thumb.url }}"{% if entry.thumb.srcset %} srcset="{{ entry.thumb.srcset }}" sizes="(max-width: 820px) 100vw, 33vw"{% endif %} alt="{{ entry.thumb.alt }}" width="{{ entry.thumb.width }}" height="{{ entry.thumb.height }}" loading="lazy"></picture></div>
        {% endif %}
        <div class="b-cbody">
          {% if entry.category %}<span class="b-ctag">{{ entry.category }}</span>{% endif %}
          <h3>{{ entry.title }}</h3>
          {% if entry.summary %}<p>{{ entry.summary }}</p>{% endif %}
          <div class="b-cmeta"><time datetime="{{ entry.date_iso }}">{{ entry.date_human }}</time><span class="b-dot">·</span><span>{{ entry.minutes }} {{ entry.min_read_label }}</span></div>
        </div>
      </a>
    {% endfor %}
    </div>
  </div>
</section>
{% elif section.kind == "story" %}
<section class="sec story" id="{{ section.key }}">
  <div class="wrap two">
    <div class="lbl">
      {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
    </div>
    <div>
      <h2>{{ section.data.heading }}</h2>
      <div class="body">{{ section.data.body }}</div>
      {% for image in section.images %}
      <picture>{% for source in image.sources %}<source type="{{ source.type }}" srcset="{{ source.srcset }}" sizes="100vw">{% endfor %}<img src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="100vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}"></picture>
      {% endfor %}
      {% if section.rows %}
      <div class="meta">
        {% for item in section.rows %}
        <div><div class="k">{{ item.label }}</div><div class="v">{{ item.value }}</div></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% elif section.kind == "expertise" %}
<section class="sec" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
    <h2>{{ section.data.heading }}</h2>
    <div class="exp">
      {% for item in section.rows %}
      <div class="row">
        <span class="no">{{ item.no }}</span>
        <h3>{{ item.title }}</h3>
        <p>{{ item.detail }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% elif section.kind == "contact" %}
<section class="sec contact" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick kick-center">{{ section.data.kicker }}</span>{% endif %}
    <p class="big">{{ section.data.heading }}{% if section.data.accent %} <em>{{ section.data.accent }}</em>{% endif %}</p>
    {% if section.data.button and nav.menu %}
    <p class="cta-row"><a class="btn btn-lg" href="{{ nav.menu[-1].url }}">{{ section.data.button }} <span class="ar">&rarr;</span></a></p>
    {% endif %}
  </div>
</section>
{% elif section.kind == "quote" %}
<section class="sec" id="{{ section.key }}">
  <div class="wrap">
    <figure class="pull-quote">
      <blockquote><p>{{ section.data.quote }}</p></blockquote>
      {% if section.data.attribution %}
      <figcaption>{{ section.data.attribution }}{% if section.data.role %} <span class="pq-role">· {{ section.data.role }}</span>{% endif %}</figcaption>
      {% endif %}
    </figure>
  </div>
</section>
{% elif section.kind == "form" %}
<section class="sec" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    {% if section.data.intro %}<div class="prose">{{ section.data.intro }}</div>{% endif %}
    {% if section.form %}
    <form method="post" action="{{ section.form.endpoint }}" class="content-form">
      <input type="hidden" name="form_page" value="{{ section.form.page_id }}">
      <input type="hidden" name="form_section" value="{{ section.key }}">
      <input type="hidden" name="form_language" value="{{ section.form.language }}">
      <input type="hidden" name="form_elapsed" value="">
      <div hidden aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
      {% for field in section.rows %}{% set input_id = section.key ~ "-" ~ field.key %}
      {% if field.type == "checkbox" %}
      <p><input type="checkbox" id="{{ input_id }}" name="field_{{ field.key }}" value="1"{% if field.required %} required aria-required="true"{% endif %}>
        <label for="{{ input_id }}">{{ field.label }}</label></p>
      {% elif field.type == "textarea" %}
      <p><label for="{{ input_id }}">{{ field.label }}</label>
        <textarea id="{{ input_id }}" name="field_{{ field.key }}" rows="5"{% if field.required %} required aria-required="true"{% endif %}></textarea></p>
      {% else %}
      <p><label for="{{ input_id }}">{{ field.label }}</label>
        <input type="{{ "email" if field.type == "email" else "text" }}" id="{{ input_id }}" name="field_{{ field.key }}"{% if field.required %} required aria-required="true"{% endif %}></p>
      {% endif %}
      {% endfor %}
      {% if section.data.consent_label %}
      <p><input type="checkbox" id="{{ section.key }}-consent" name="consent" value="1" required aria-required="true">
        <label for="{{ section.key }}-consent">{{ section.data.consent_label }}</label></p>
      {% endif %}
      {% if section.data.submit_label %}<p><button type="submit" class="btn">{{ section.data.submit_label }}</button></p>{% endif %}
    </form>
    {% if section.data.success_heading or section.data.success_text %}
    <div hidden data-form-success>
      {% if section.data.success_heading %}<h3>{{ section.data.success_heading }}</h3>{% endif %}
      {% if section.data.success_text %}<p>{{ section.data.success_text }}</p>{% endif %}
    </div>
    {% endif %}
    {% endif %}
  </div>
</section>
{% elif section.kind == "faq" %}
<section class="sec" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    <div class="faq-list">
      {% for item in section.rows %}
      <details class="faq-item">
        <summary>{{ item.question }}</summary>
        <p>{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% elif section.kind == "cta" %}
<section class="sec contact" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick kick-center">{{ section.data.kicker }}</span>{% endif %}
    <p class="big">{{ section.data.heading }}</p>
    {% if section.data.body %}<div class="cta-body">{{ section.data.body }}</div>{% endif %}
    {% if section.data.button and section.data.url %}
    <p class="cta-row"><a class="btn btn-lg" href="{{ section.data.url }}">{{ section.data.button }} <span class="ar">&rarr;</span></a></p>
    {% endif %}
  </div>
</section>
{% elif section.kind == "gallery" %}
<section class="sec" id="{{ section.key }}">
  <div class="wrap">
    {% if section.data.kicker %}<span class="kick">{{ section.data.kicker }}</span>{% endif %}
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    <div class="g-grid">
      {% for image in section.images %}
      <figure class="g-item"><picture>{% for source in image.sources %}<source type="{{ source.type }}" srcset="{{ source.srcset }}" sizes="(max-width: 820px) 100vw, 50vw">{% endfor %}<img src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="(max-width: 820px) 100vw, 50vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}" loading="lazy"></picture></figure>
      {% endfor %}
    </div>
  </div>
</section>
{% else %}
<section class="sec section-{{ section.kind }}" id="{{ section.key }}">
  <div class="wrap">
    {% for name, value in section.data | dictsort %}
    <div class="field field-{{ name }}">{{ value }}</div>
    {% endfor %}
    {% for image in section.images %}
    <picture>{% for source in image.sources %}<source type="{{ source.type }}" srcset="{{ source.srcset }}" sizes="100vw">{% endfor %}<img src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="100vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}"></picture>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endfor %}
{% endblock %}
