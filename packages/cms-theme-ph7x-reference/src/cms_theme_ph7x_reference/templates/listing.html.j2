{% extends "base.html.j2" %}
{% block styles %}
<link rel="stylesheet" href="{{ asset_urls['assets/legal.css'] }}">
<link rel="stylesheet" href="{{ asset_urls['assets/blog.css'] }}">
{% endblock %}
{% block backdrop %}
<div class="aurora" aria-hidden="true"><span class="a1"></span><span class="a2"></span></div>
{% endblock %}
{% block main %}
<section class="b-hero">
  {% if listing.eyebrow and listing.eyebrow != listing.title %}<span class="eyebrow">{{ listing.eyebrow }}</span>{% endif %}
  <h1>{{ listing.title }}</h1>
  {% if listing.sub %}<p class="sub">{{ listing.sub }}</p>{% endif %}
</section>
{% if listing.search_index_url %}
<div class="b-tools">
  <site-search index-url="{{ listing.search_index_url }}" label="{{ listing.search_label }}"></site-search>
  {# CSS-only cards/list toggle (no JS, ADR-0010): radios drive .b-grid via :has(). #}
  <div class="b-views" role="group" aria-label="{{ listing.view_cards_label }} / {{ listing.view_list_label }}">
    <label class="bv"><input type="radio" name="bview" id="bv-cards" checked aria-label="{{ listing.view_cards_label }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></label>
    <label class="bv"><input type="radio" name="bview" id="bv-list" aria-label="{{ listing.view_list_label }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3.5 6h.01M3.5 12h.01M3.5 18h.01"/></svg></label>
  </div>
</div>
<script type="module" src="{{ asset_urls['assets/search.js'] }}"></script>
{% endif %}
{% if listing.filters %}
<nav class="b-filters" aria-label="Categories">
  {% for entry in listing.filters %}<a href="{{ entry.url }}">{{ entry.label }}</a>{% endfor %}
</nav>
{% endif %}
<div class="b-grid">
{% for entry in listing.entries %}
  <a class="b-card" href="{{ entry.url }}">
    {% if entry.thumb %}
    <div class="b-thumb"><img src="{{ entry.thumb.url }}" alt="{{ entry.thumb.alt }}" width="{{ entry.thumb.width }}" height="{{ entry.thumb.height }}" loading="lazy"></div>
    {% endif %}
    <div class="b-cbody">
      {% if entry.category %}<span class="b-ctag">{{ entry.category }}</span>{% endif %}
      <h2>{{ entry.title }}</h2>
      {% if entry.summary %}<p>{{ entry.summary }}</p>{% endif %}
      <div class="b-cmeta"><time datetime="{{ entry.date_iso }}">{{ entry.date_human }}</time><span class="b-dot">·</span><span>{{ entry.minutes }} {{ entry.min_read_label }}</span></div>
    </div>
  </a>
{% endfor %}
</div>
{% if listing.pages > 1 %}
<nav class="b-pager" aria-label="Pagination">
  {% if listing.previous_url %}<a rel="prev" href="{{ listing.previous_url }}">&larr;</a>{% endif %}
  <span>{{ listing.page }} / {{ listing.pages }}</span>
  {% if listing.next_url %}<a rel="next" href="{{ listing.next_url }}">&rarr;</a>{% endif %}
</nav>
{% endif %}
{% endblock %}
