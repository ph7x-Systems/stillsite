msgstr "le rapport de validation vous dit s'il manque quelque chose."

msgid "A plain folder of files — upload the output directory to any static host or shared hosting."
msgstr "Un simple dossier de fichiers — téléversez le répertoire de sortie vers n'importe quel hébergement statique ou mutualisé."

msgid "Any static host"
msgstr "N'importe quel hébergement statique"

msgid "Azure Static Web Apps"
msgstr "Azure Static Web Apps"

