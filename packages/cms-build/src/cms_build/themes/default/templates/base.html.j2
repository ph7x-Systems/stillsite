<!DOCTYPE html>
<html lang="{{ head.language.value }}"{% if head.direction == "rtl" %} dir="rtl"{% endif %}>
<head>
{% include "_head.html.j2" %}
{% block fonts %}{% endblock %}
<link rel="stylesheet" href="{{ asset_urls['assets/site.css'] }}">
</head>
<body>
<header class="site-header">
  <nav class="site-nav" aria-label="Main">
    <a class="brand" href="{{ nav.home_url }}">{{ head.site_name }}</a>
    <ul class="menu">
    {% for entry in nav.menu %}
      <li><a href="{{ entry.url }}">{{ entry.label }}</a></li>
    {% endfor %}
    </ul>
    <ul class="languages">
    {% for entry in nav.languages %}
      <li><a href="{{ entry.url }}"{% if entry.current %} aria-current="true"{% endif %}>{{ entry.code }}</a></li>
    {% endfor %}
    </ul>
  </nav>
</header>
<main>
{% block main %}{% endblock %}
</main>
<footer class="site-footer">
  <ul class="menu">
  {% for entry in footer.menu %}
    <li><a href="{{ entry.url }}">{{ entry.label }}</a></li>
  {% endfor %}
  </ul>
  <p>{{ footer.text }}</p>
</footer>
</body>
</html>
