{% extends "base.html.j2" %}
{% block main %}
<article class="page">
  <h1>{{ page.title }}</h1>
  {% if page.description %}
  <p class="lead">{{ page.description }}</p>
  {% endif %}
  {% if page.body_html %}
  <div class="page-body">{{ page.body_html }}</div>
  {% endif %}
  {% for section in sections %}
  {% if section.kind == "latest-articles" %}
  <section class="section latest" id="{{ section.key }}">
    {% for name, value in section.fields %}
    {% if name == "heading" %}<h2>{{ value }}</h2>{% else %}<p>{{ value }}</p>{% endif %}
    {% endfor %}
    <ul class="entries">
    {% for entry in latest %}
      <li>
        <a href="{{ entry.url }}">{{ entry.title }}</a>
        {% if entry.summary %}<p>{{ entry.summary }}</p>{% endif %}
        <time datetime="{{ entry.date_iso }}">{{ entry.date_iso }}</time>
      </li>
    {% endfor %}
    </ul>
  </section>
  {% elif section.kind == "quote" %}
  <section class="section quote" id="{{ section.key }}">
    <figure>
      <blockquote><p>{{ section.data.quote }}</p></blockquote>
      {% if section.data.attribution %}
      <figcaption>{{ section.data.attribution }}{% if section.data.role %}, {{ section.data.role }}{% endif %}</figcaption>
      {% endif %}
    </figure>
  </section>
  {% elif section.kind == "faq" %}
  <section class="section faq" id="{{ section.key }}">
    {% if section.data.kicker %}<p class="kicker">{{ section.data.kicker }}</p>{% endif %}
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    {% for item in section.rows %}
    <details>
      <summary>{{ item.question }}</summary>
      <p>{{ item.answer }}</p>
    </details>
    {% endfor %}
  </section>
  {% elif section.kind == "cta" %}
  <section class="section cta" id="{{ section.key }}">
    {% if section.data.kicker %}<p class="kicker">{{ section.data.kicker }}</p>{% endif %}
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    {% if section.data.body %}<div class="body">{{ section.data.body }}</div>{% endif %}
    {% if section.data.button and section.data.url %}
    <p><a class="button" href="{{ section.data.url }}">{{ section.data.button }}</a></p>
    {% endif %}
  </section>
  {% elif section.kind == "gallery" %}
  <section class="section gallery" id="{{ section.key }}">
    {% if section.data.kicker %}<p class="kicker">{{ section.data.kicker }}</p>{% endif %}
    {% if section.data.heading %}<h2>{{ section.data.heading }}</h2>{% endif %}
    <div class="gallery-grid">
      {% for image in section.images %}
      <figure><img src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="(max-width: 820px) 100vw, 50vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}" loading="lazy"></figure>
      {% endfor %}
    </div>
  </section>
  {% else %}
  <section class="section section-{{ section.kind }}" id="{{ section.key }}">
    {% for name, value in section.data | dictsort %}
    <div class="field field-{{ name }}">{{ value }}</div>
    {% endfor %}
    {% for item in section.rows %}
    <div class="item">
      {% for name, value in item | dictsort %}
      <div class="field field-{{ name }}">{{ value }}</div>
      {% endfor %}
    </div>
    {% endfor %}
    {% for image in section.images %}
    <img src="{{ image.url }}"{% if image.srcset %} srcset="{{ image.srcset }}" sizes="100vw"{% endif %} alt="{{ image.alt }}" width="{{ image.width }}" height="{{ image.height }}">
    {% endfor %}
  </section>
  {% endif %}
  {% endfor %}
</article>
{% endblock %}
