{% extends "base.html.j2" %}
{% block main %}
<article class="article">
  <h1>{{ article.title }}</h1>
  {% if article.summary %}
  <p class="lead">{{ article.summary }}</p>
  {% endif %}
  <p class="meta">
    {% if article.author %}<span class="byline">{{ article.author }}</span> · {% endif %}
    <time datetime="{{ article.date_iso }}">{{ article.date_iso }}</time>
    {% if article.category %}
    · <a class="category" href="{{ article.category.url }}">{{ article.category.label }}</a>
    {% endif %}
  </p>
  <div class="body">{{ article.body_html }}</div>
  {% if article.tags %}
  <ul class="tags">
    {% for tag in article.tags %}
    <li><a href="{{ tag.url }}">#{{ tag.slug }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
  {% if comments %}
  {# ADR-0031: the link is the no-JS surface; the island upgrades it and
     contacts nothing before the reader acts. #}
  <section class="comments">
    <site-comments data-thread-url="{{ comments.thread_url }}">
      <a href="{{ comments.thread_url }}" rel="external nofollow">{{ comments.label }}</a>
    </site-comments>
  </section>
  <script type="module" src="{{ comments.island_url }}"></script>
  {% endif %}
</article>
{% endblock %}
