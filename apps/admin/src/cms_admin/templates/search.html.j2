{% extends "shell.html.j2" %}
{% block title %}{{ _("Search") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Search") }}</h1>{% endblock %}
{% block content %}
<form method="get" action="/search" role="search" class="admin-form mb-3">
  <div class="d-flex gap-2">
    <label class="mb-0 flex-grow-1">
      <span class="visually-hidden admin-visually-hidden">{{ _("Search") }}</span>
      <input class="form-control admin-input" type="search" name="q" value="{{ q }}"
             placeholder="{{ _('Search everything you can edit') }}" autofocus>
    </label>
    <button type="submit" class="btn btn-primary">{{ _("Search") }}</button>
  </div>
</form>
{% if q %}
<p class="form-text">{{ _("%(total)s result(s) for") | format(total=total) }} <strong>{{ q }}</strong></p>
{% for kind, rows in groups %}
<div class="card mb-3">
  <div class="card-header"><h2 class="card-title h6 mb-0">
    {% if kind == "article" %}{{ _("Articles") }}{% elif kind == "page" %}{{ _("Pages") }}
    {% elif kind == "section" %}{{ _("Sections") }}{% else %}{{ _("Media") }}{% endif %}
  </h2></div>
  <div class="card-body p-0">
    <ul class="list-group list-group-flush">
      {% for row in rows %}
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <a href="{{ row.url }}">{{ row.title }}</a>
        {% if row.detail %}<span class="badge text-bg-light border admin-tag">{{ row.detail }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</div>
{% endfor %}
{% if not groups %}
<p class="admin-empty">{{ _("Nothing matched. Search covers titles, text, slugs, section fields and media alt text — in every language.") }}</p>
{% endif %}
{% endif %}
{% endblock %}
