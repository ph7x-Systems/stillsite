{% extends "shell.html.j2" %}
{% block title %}{{ _("Two-factor authentication") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Two-factor authentication") }}</h1>{% endblock %}
{% block content %}
{% if error %}<p role="alert" class="alert alert-danger admin-alert">{{ _(error) }}</p>{% endif %}
<div class="card">
  <div class="card-body">
    {% if enabled %}
    <p role="status" class="alert alert-success admin-alert">{{ _("Two-factor authentication is enabled.") }}</p>
    <form method="post" action="/profile/2fa/disable">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="mb-3 admin-field">
        <label class="form-label" for="code">{{ _("Authentication code") }}</label>
        <input class="form-control admin-input" id="code" name="code" type="text"
               inputmode="numeric" autocomplete="one-time-code" required>
      </div>
      <button type="submit" class="btn btn-outline-danger">{{ _("Disable two-factor authentication") }}</button>
    </form>
    {% else %}
    <p>{{ _("Enter this key in your authenticator app, then confirm with a code:") }}</p>
    <dl class="row">
      <dt class="col-sm-3">{{ _("Manual key") }}</dt>
      <dd class="col-sm-9"><code>{{ secret }}</code></dd>
      <dt class="col-sm-3">{{ _("Setup link") }}</dt>
      <dd class="col-sm-9"><a href="{{ uri }}"><code>{{ uri }}</code></a></dd>
    </dl>
    <form method="post" action="/profile/2fa/enable">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <input type="hidden" name="secret" value="{{ secret }}">
      <div class="mb-3 admin-field">
        <label class="form-label" for="code">{{ _("Authentication code") }}</label>
        <input class="form-control admin-input" id="code" name="code" type="text"
               inputmode="numeric" autocomplete="one-time-code" required>
      </div>
      <button type="submit" class="btn btn-primary">{{ _("Verify and enable") }}</button>
    </form>
    {% endif %}
  </div>
</div>
{% endblock %}
