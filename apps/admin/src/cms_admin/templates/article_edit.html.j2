{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import content_fields, metadata_fields, errors_block, state_badge, status_tag %}
{% block title %}{{ article.id }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/articles">&larr; Articles</a></nav>
<h1 class="h3 mb-0">{{ article.id }} {{ status_tag(article.status) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
{% if transitions %}
<div class="mb-3 d-flex gap-2 admin-workflow" role="group" aria-label="Workflow">
  {% for t in transitions %}
  <form method="post" action="/articles/{{ article.id }}/status" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="to" value="{{ t.to }}">
    <button type="submit" class="btn {{ 'btn-success' if t.to == 'published' else 'btn-outline-secondary' }}">{{ t.label }}</button>
  </form>
  {% endfor %}
</div>
{% endif %}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <form method="post" action="/articles/{{ article.id }}" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">Source (EN)</h2></div>
        <div class="card-body">{{ content_fields(form) }}</div>
      </div>
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">Metadata</h2></div>
        <div class="card-body">{{ metadata_fields(form) }}</div>
      </div>
      <button type="submit" class="btn btn-primary mb-3">Save</button>
    </form>
  </div>
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">Preview</h2></div>
      <div class="card-body">
        <p class="form-text">Rendered with the builder's Markdown renderer (raw HTML disabled);
          shows the last saved body.</p>
        <div class="admin-preview">{{ preview_html | safe }}</div>
      </div>
    </div>
  </div>
</div>
<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">Translations</h2></div>
  <div class="card-body p-0 admin-table-wrap">
    <table class="table table-striped mb-0 admin-table">
      <thead>
        <tr><th scope="col">Language</th><th scope="col">State</th><th scope="col">Title</th><th scope="col"></th></tr>
      </thead>
      <tbody>
        {% for language in target_languages %}
        {% set translation = article.translations.get(language) %}
        <tr>
          <th scope="row">{{ language.value | upper }}</th>
          <td>{{ state_badge(states[language]) }}</td>
          <td>{{ translation.content.title if translation else "" }}</td>
          <td><a href="/articles/{{ article.id }}/translations/{{ language.value }}">Edit translation</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
