{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import content_fields, metadata_fields, errors_block, state_badge, status_tag with context %}
{% block title %}{{ article.id }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/articles">&larr; {{ _("Articles") }}</a></nav>
<h1 class="h3 mb-0">{{ article.id }} {{ status_tag(article.status) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
<div class="d-flex gap-2 mb-3">
  <form method="post" action="/articles/{{ article.id }}/duplicate" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="btn btn-outline-secondary btn-sm">{{ _("Duplicate as draft") }}</button>
  </form>
  {% if preview_path %}
  <a class="btn btn-outline-secondary btn-sm" href="{{ preview_path }}">{{ _("View in preview") }}</a>
  {% endif %}
  <form method="post" action="/trash/article/{{ article.id }}" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="btn btn-outline-danger btn-sm">{{ _("Move to trash") }}</button>
  </form>
</div>
{% if transitions %}
<div class="mb-3 d-flex gap-2 admin-workflow" role="group" aria-label="{{ _('Workflow') }}">
  {% for t in transitions %}
  <form method="post" action="/articles/{{ article.id }}/status" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="to" value="{{ t.to }}">
    <button type="submit" class="btn {{ 'btn-success' if t.to == 'published' else 'btn-outline-secondary' }}">{{ _(t.label) }}</button>
  </form>
  {% endfor %}
</div>
{% endif %}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <form method="post" action="/articles/{{ article.id }}" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Source (EN)") }}</h2></div>
        <div class="card-body">{{ content_fields(form) }}</div>
      </div>
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Metadata") }}</h2></div>
        <div class="card-body">{{ metadata_fields(form) }}</div>
      </div>
      <button type="submit" class="btn btn-primary mb-3">{{ _("Save") }}</button>
    </form>
  </div>
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Preview") }}</h2></div>
      <div class="card-body">
        <p class="form-text">{{ _("Rendered with the builder's Markdown renderer (raw HTML disabled); shows the last saved body.") }}</p>
        <div class="admin-preview">{{ preview_html | safe }}</div>
      </div>
    </div>
  </div>
</div>
<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Translations") }}</h2></div>
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped mb-0 admin-table">
      <thead>
        <tr><th scope="col">{{ _("Language") }}</th><th scope="col">{{ _("State") }}</th><th scope="col">{{ _("Title") }}</th><th scope="col"></th></tr>
      </thead>
      <tbody>
        {% for language in target_languages %}
        {% set translation = article.translations.get(language) %}
        <tr>
          <th scope="row">{{ language.value | upper }}</th>
          <td>{{ state_badge(states[language]) }}</td>
          <td>{{ translation.content.title if translation else "" }}</td>
          <td><a href="/articles/{{ article.id }}/translations/{{ language.value }}">{{ _("Edit translation") }}</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% include "_design_preview.html.j2" %}
{% set base_url = "/articles/" ~ article.id %}
{% include "_revisions.html.j2" %}
{% endblock %}
