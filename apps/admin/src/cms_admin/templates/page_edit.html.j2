{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import text_field, textarea_field, datetime_field, errors_block, state_badge, status_tag, translation_badges with context %}
{% block title %}{{ page.id }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/pages">&larr; {{ _("Pages") }}</a></nav>
<h1 class="h3 mb-0">{{ page.id }} {{ status_tag(page.status) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
{% if undo_delete %}
<div class="alert alert-warning d-flex align-items-center justify-content-between" role="status">
  <span>{{ _("Section %(key)s was deleted.") | format(key=undo_delete.key) }}</span>
  <form method="post" action="/pages/{{ page.id }}/sections/restore" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="payload" value="{{ undo_delete.payload }}">
    <input type="hidden" name="position" value="{{ undo_delete.position }}">
    <button type="submit" class="btn btn-outline-dark btn-sm">{{ _("Undo") }}</button>
  </form>
</div>
{% endif %}
<div class="d-flex gap-2 mb-3">
  <form method="post" action="/pages/{{ page.id }}/duplicate" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="btn btn-outline-secondary btn-sm">{{ _("Duplicate as draft") }}</button>
  </form>
  {% if preview_path %}
  <a class="btn btn-outline-secondary btn-sm" href="{{ preview_path }}">{{ _("View in preview") }}</a>
  {% endif %}
  <form method="post" action="/trash/page/{{ page.id }}" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="btn btn-outline-danger btn-sm">{{ _("Move to trash") }}</button>
  </form>
</div>
{% if transitions %}
<div class="mb-3 d-flex gap-2 admin-workflow" role="group" aria-label="{{ _('Workflow') }}">
  {% for t in transitions %}
  <form method="post" action="/pages/{{ page.id }}/status" class="mb-0">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="to" value="{{ t.to }}">
    <button type="submit" class="btn {{ 'btn-success' if t.to == 'published' else 'btn-outline-secondary' }}">{{ _(t.label) }}</button>
  </form>
  {% endfor %}
</div>
{% endif %}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <form method="post" action="/pages/{{ page.id }}" class="admin-form"
          data-autosave data-autosave-url="/pages/{{ page.id }}/autosave">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Content (EN)") }}</h2></div>
        <div class="card-body">
          {{ text_field("title", _("Title"), form.title, required=true) }}
          {{ textarea_field("description", _("Description"), form.description, rows=3) }}
          {{ textarea_field("body_markdown", _("Body (Markdown)"), form.body_markdown, rows=8, markdown=true) }}
          {{ text_field("slug", _("Slug"), form.slug, required=true) }}
          {{ datetime_field("publish_at", _("Publish at (UTC)"), form.publish_at,
                            hint=_("empty publishes immediately once published; a future moment keeps the entry out of builds until a build runs after it")) }}
          {{ datetime_field("unpublish_at", _("Unpublish at (UTC)"), form.unpublish_at,
                  hint=_("optional end of the window — after this moment the next build drops the entry; must fall after the publish moment")) }}
        </div>
      </div>
      <p class="form-text" role="status" aria-live="polite" data-autosave-status
         data-saving="{{ _('Saving…') }}" data-saved="{{ _('Saved') }}"
         data-invalid="{{ _('Autosave paused — fix invalid fields.') }}"></p>
      <button type="submit" class="btn btn-primary mb-3">{{ _("Save") }}</button>
    </form>
  </div>
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Page translations") }}</h2></div>
      <div class="card-body p-0 table-responsive admin-table-wrap">
        <table class="table table-striped mb-0 admin-table">
          <thead><tr><th scope="col">{{ _("Language") }}</th><th scope="col">{{ _("State") }}</th><th scope="col"></th></tr></thead>
          <tbody>
            {% for language in target_languages %}
            <tr>
              <th scope="row">{{ language.value | upper }}</th>
              <td>{{ state_badge(own_states[language]) }}</td>
              <td><a href="/pages/{{ page.id }}/translations/{{ language.value }}">{{ _("Edit translation") }}</a></td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="card-footer form-text">{{ _("The page's own title/description/slug — section content is translated on each section.") }}</div>
    </div>
  </div>
</div>
<div class="card mb-3">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Sections") }}</h2></div>
  {% if page.sections %}
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">{{ _("Key") }}</th>
          <th scope="col">{{ _("Kind") }}</th>
          <th scope="col">{{ _("Translations") }}</th>
          <th scope="col">{{ _("Actions") }}</th>
        </tr>
      </thead>
      <tbody>
        {% for section in page.sections %}
        <tr draggable="true" data-section-key="{{ section.key }}" class="admin-draggable{% if section.hidden %} admin-section-hidden{% endif %}">
          <td class="text-end"><span class="admin-drag-handle" aria-hidden="true">&#8942;&#8942;</span> {{ loop.index }}</td>
          <th scope="row"><a href="/pages/{{ page.id }}/sections/{{ section.key }}">{{ section.key }}</a></th>
          <td>{{ section.kind }}
            {% if section.hidden %}<span class="badge text-bg-secondary">{{ _("Hidden") }}</span>{% endif %}
            {% if section.kind in generic_kinds %}<span class="badge text-bg-light border" title="{{ _("Renders generically in the current theme.") }}">{{ _("generic") }}</span>{% endif %}</td>
          <td>{{ translation_badges(section, target_languages) }}</td>
          <td class="admin-row-actions d-flex gap-1">
            <form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}/move" class="mb-0">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="direction" value="up">
              <button type="submit" class="btn btn-outline-secondary btn-sm" {% if loop.first %}disabled{% endif %}
                      aria-label="{{ _('Move %(key)s up') | format(key=section.key) }}">&uarr;</button>
            </form>
            <form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}/move" class="mb-0">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="direction" value="down">
              <button type="submit" class="btn btn-outline-secondary btn-sm" {% if loop.last %}disabled{% endif %}
                      aria-label="{{ _('Move %(key)s down') | format(key=section.key) }}">&darr;</button>
            </form>
            <form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}/duplicate" class="mb-0">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="btn btn-outline-secondary btn-sm"
                      aria-label="{{ _('Duplicate section %(key)s') | format(key=section.key) }}">{{ _("Duplicate") }}</button>
            </form>
            <form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}/visibility" class="mb-0">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="action" value="{{ 'show' if section.hidden else 'hide' }}">
              <button type="submit" class="btn btn-outline-secondary btn-sm"
                      aria-label="{{ (_('Show section %(key)s') if section.hidden else _('Hide section %(key)s')) | format(key=section.key) }}">
                {{ _("Show") if section.hidden else _("Hide") }}</button>
            </form>
            <form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}/delete" class="mb-0">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="btn btn-outline-danger btn-sm"
                      aria-label="{{ _('Remove section %(key)s') | format(key=section.key) }}">{{ _("Remove") }}</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <form method="post" action="/pages/{{ page.id }}/sections/order" class="mb-0" data-section-order-form hidden>
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    </form>
  </div>
  {% else %}
  <div class="card-body"><p class="admin-empty mb-0">{{ _("No sections yet.") }}</p></div>
  {% endif %}
</div>
<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Add a block") }}</h2></div>
  <div class="card-body">
    {% set gallery_meta = {
      "hero": ("bi-fonts", _("Opening statement with a large heading.")),
      "story": ("bi-body-text", _("Narrative prose with stat pairs and images.")),
      "expertise": ("bi-list-ol", _("Numbered capability rows.")),
      "latest-articles": ("bi-newspaper", _("The most recent blog entries, automatic.")),
      "quote": ("bi-quote", _("A pull quote with attribution.")),
      "faq": ("bi-patch-question", _("Questions and answers as native disclosures.")),
      "cta": ("bi-megaphone", _("A call to action with a button.")),
      "gallery": ("bi-images", _("An image grid from the section's media.")),
      "form": ("bi-ui-checks", _("A visitor form; its items declare the inputs.")),
      "contact": ("bi-envelope", _("Closing call to action.")),
    } %}
    <div class="row g-2 admin-block-gallery">
      {% for kind in kind_hints %}
      {% set meta = gallery_meta.get(kind) %}
      <div class="col-12 col-sm-6 col-lg-4">
        <form method="post" action="/pages/{{ page.id }}/sections" class="mb-0 h-100">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <input type="hidden" name="kind" value="{{ kind }}">
          <button type="submit" class="card h-100 w-100 text-start admin-block-card">
            <span class="card-body d-block">
              <span class="d-block fw-semibold"><i class="bi {{ meta[0] if meta else 'bi-puzzle' }}" aria-hidden="true"></i> {{ kind }}</span>
              <span class="d-block form-text">{{ meta[1] if meta else _("Contributed by an extension; renders by its own template or generically.") }}</span>
            </span>
          </button>
        </form>
      </div>
      {% endfor %}
    </div>
    <details class="mt-3">
      <summary class="form-text">{{ _("Custom kind (advanced)") }}</summary>
      <form method="post" action="/pages/{{ page.id }}/sections" class="admin-form mt-2">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        {{ text_field("kind", _("Kind"), "", required=true,
                      hint=_("the theme template that renders it — unknown kinds render generically")) }}
        {{ text_field("key", _("Key"), "", hint=_("optional — derived from the kind when empty")) }}
        <button type="submit" class="btn btn-primary">{{ _("Add section") }}</button>
      </form>
    </details>
  </div>
</div>
{% include "_notes.html.j2" %}
{% include "_design_preview.html.j2" %}
{% set base_url = "/pages/" ~ page.id %}
{% include "_revisions.html.j2" %}
{% endblock %}
