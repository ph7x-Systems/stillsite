{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import translation_badges, status_tag, row_actions with context %}
{% block title %}{{ _("Pages") }} — Sardine CMS admin{% endblock %}
{% block header %}
<div class="d-flex justify-content-between align-items-center">
  <h1 class="h3 mb-0">{{ _("Pages") }}</h1>
  <a class="btn btn-primary" href="/pages/new">{{ _("New page") }}</a>
</div>
{% endblock %}
{% block content %}
{% if pages %}
<div class="card">
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped table-hover mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col"><span class="visually-hidden">{{ _("Select") }}</span></th>
          <th scope="col">{{ _("ID") }}</th>
          <th scope="col">{{ _("Title (EN)") }}</th>
          <th scope="col">{{ _("Status") }}</th>
          <th scope="col">{{ _("Sections") }}</th>
          <th scope="col">{{ _("Translations") }}</th>
          <th scope="col">{{ _("Updated") }}</th>
          <th scope="col"><span class="visually-hidden">{{ _("Actions") }}</span></th>
        </tr>
      </thead>
      <tbody>
        {% for page in pages %}
        <tr>
          <td><label class="mb-0"><span class="visually-hidden admin-visually-hidden">{{ _("Select %(id)s") | format(id=page.id) }}</span>
            <input class="form-check-input" type="checkbox" name="selected" value="{{ page.id }}" form="bulk-form"></label></td>
          <th scope="row"><a href="/pages/{{ page.id }}">{{ page.id }}</a></th>
          <td>{{ page.source.title }}</td>
          <td>{{ status_tag(page.status) }}</td>
          <td class="text-end">{{ page.sections | length }}</td>
          <td>{{ translation_badges(page, target_languages) }}</td>
          <td>{{ page.updated_at.strftime("%Y-%m-%d") }}</td>
          <td>{{ row_actions("page", page.id, row_actions_map[page.id]) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="card-footer form-text">{{ _("Language states aggregate the page and all its sections — the least-complete state wins.") }}</div>
</div>
<form method="post" action="/pages/bulk" id="bulk-form" class="card mt-3">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card-body d-flex flex-wrap gap-2 align-items-center">
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Bulk action") }}</span>
      <select class="form-select admin-input" name="action">
        <option value="to-review">{{ _("Submit for review") }}</option>
        <option value="to-draft">{{ _("Send back to draft") }}</option>
        <option value="publish">{{ _("Publish") }}</option>
        <option value="archive">{{ _("Archive") }}</option>
        <option value="trash">{{ _("Move to trash") }}</option>
      </select>
    </label>
    <button type="submit" class="btn btn-outline-primary">{{ _("Apply to selected") }}</button>
    <span class="form-text mb-0">{{ _("Each entry keeps its own rules — the report shows every outcome.") }}</span>
  </div>
</form>
{% else %}
<p class="admin-empty">{{ _("No pages yet — create the first one.") }}</p>
{% endif %}
{% endblock %}
