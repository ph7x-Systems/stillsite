{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import state_badge, status_tag with context %}
{% block title %}{{ _("Pages") }} — Sardine CMS admin{% endblock %}
{% block header %}
<div class="d-flex justify-content-between align-items-center">
  <h1 class="h3 mb-0">{{ _("Pages") }}</h1>
  <a class="btn btn-primary" href="/pages/new">{{ _("New page") }}</a>
</div>
{% endblock %}
{% block content %}
{% if pages %}
<div class="card">
  <div class="card-body p-0 admin-table-wrap">
    <table class="table table-striped table-hover mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col">{{ _("ID") }}</th>
          <th scope="col">{{ _("Title (EN)") }}</th>
          <th scope="col">{{ _("Status") }}</th>
          <th scope="col">{{ _("Sections") }}</th>
          {% for language in target_languages %}<th scope="col">{{ language.value | upper }}</th>{% endfor %}
          <th scope="col">{{ _("Updated") }}</th>
        </tr>
      </thead>
      <tbody>
        {% for page in pages %}
        <tr>
          <th scope="row"><a href="/pages/{{ page.id }}">{{ page.id }}</a></th>
          <td>{{ page.source.title }}</td>
          <td>{{ status_tag(page.status) }}</td>
          <td class="text-end">{{ page.sections | length }}</td>
          {% for language in target_languages %}
          <td>{{ state_badge(page.translation_state(language)) }}</td>
          {% endfor %}
          <td>{{ page.updated_at.strftime("%Y-%m-%d") }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="card-footer form-text">{{ _("Language states aggregate the page and all its sections — the least-complete state wins.") }}</div>
</div>
{% else %}
<p class="admin-empty">{{ _("No pages yet — create the first one.") }}</p>
{% endif %}
{% endblock %}
