{% extends "base.html.j2" %}
{% block title %}Sign in — Sardine CMS admin{% endblock %}
{% block bodyclass %}login-page bg-body-secondary{% endblock %}
{% block body %}
<main id="main" class="login-box">
  <div class="card card-outline card-primary admin-login">
    <div class="card-header text-center">
      <svg class="admin-login-mark" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#0e1626"/><g transform="translate(32 32) rotate(-38)"><ellipse rx="17" ry="7" fill="none" stroke="#d8cfc0" stroke-width="2.5"/><path fill="#d8cfc0" d="M-17 0 Q-21 -3.5 -24 -5 Q-22 -1.8 -22 0 Q-22 1.8 -24 5 Q-21 3.5 -17 0Z"/><circle cx="12" cy="-1.5" r="1.6" fill="#0e1626" stroke="#d8cfc0" stroke-width="1.4"/></g></svg>
      <span class="h4 d-block">Sardine CMS <small class="text-body-secondary">admin</small></span>
    </div>
    <div class="card-body">
      <h1 class="login-box-msg h5">Sign in</h1>
      {% if error %}<p role="alert" class="alert alert-danger admin-alert">{{ error }}</p>{% endif %}
      <form method="post" action="/login">
        <input type="hidden" name="login_csrf" value="{{ login_csrf }}">
        <div class="mb-3 admin-field">
          <label class="form-label" for="username">Username</label>
          <input class="form-control admin-input" id="username" name="username" type="text"
                 autocomplete="username" required>
        </div>
        <div class="mb-3 admin-field">
          <label class="form-label" for="password">Password</label>
          <input class="form-control admin-input" id="password" name="password" type="password"
                 autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">Sign in</button>
      </form>
    </div>
  </div>
</main>
{% endblock %}
