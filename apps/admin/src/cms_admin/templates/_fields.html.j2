{# Shared form building blocks for the editorial pages (Bootstrap idiom). #}

{% macro text_field(name, label, value, required=false, hint=None) %}
<div class="mb-1 admin-field">
  <label class="form-label" for="{{ name }}">{{ label }}</label>
  <input class="form-control admin-input" id="{{ name }}" name="{{ name }}" type="text"
         value="{{ value }}"{% if required %} required{% endif %}>
  {% if hint %}<div class="form-text admin-hint">{{ hint }}</div>{% endif %}
</div>
{% endmacro %}

{% macro textarea_field(name, label, value, rows=12, markdown=false) %}
<div class="mb-1 admin-field">
  <label class="form-label" for="{{ name }}">{{ label }}</label>
  <textarea class="form-control admin-input admin-textarea" id="{{ name }}" name="{{ name }}"
            rows="{{ rows }}"{% if markdown %} data-markdown-editor
            data-markdown-labels="{{ {"bold": _("Bold"), "italic": _("Italic"),
              "heading": _("Heading"), "quote": _("Quote"),
              "unordered-list": _("Unordered list"), "ordered-list": _("Ordered list"),
              "link": _("Create link"), "image": _("Insert image"),
              "code": _("Code"), "guide": _("Markdown guide")} | tojson }}"{% endif %}>{{ value }}</textarea>
</div>
{% endmacro %}

{% macro content_fields(form) %}
{{ text_field("title", _("Title"), form.title, required=true) }}
{{ textarea_field("summary", _("Summary"), form.summary, rows=3) }}
{{ textarea_field("body_markdown", _("Body (Markdown)"), form.body_markdown, rows=16, markdown=true) }}
{{ text_field("slug", _("Slug"), form.slug, hint=_("lowercase-with-dashes; empty falls back to the article id")) }}
{% endmacro %}

{% macro datetime_field(name, label, value, hint=None) %}
<div class="mb-1 admin-field">
  <label class="form-label" for="{{ name }}">{{ label }}</label>
  <input class="form-control admin-input" id="{{ name }}" name="{{ name }}"
         type="datetime-local" value="{{ value }}">
  {% if hint %}<div class="form-text admin-hint">{{ hint }}</div>{% endif %}
</div>
{% endmacro %}

{% macro picker_tile_meta(asset, widest) %}
<span class="d-block"><code>{{ asset.id }}</code></span>
<span class="form-text d-block">{{ asset.display_size[0] }}&times;{{ asset.display_size[1] }}{% if widest and asset.display_size[0] and asset.display_size[0] < widest %} &middot; {{ _("below the widest configured size") }}{% endif %}</span>
{% endmacro %}

{% macro cover_picker(assets, current, widest) %}
{% if assets %}
<details class="mb-2">
  <summary class="form-text">{{ _("Choose from the library") }}</summary>
  <div class="d-flex flex-wrap gap-2 mt-2" role="radiogroup" aria-label="{{ _("Cover") }}">
    <label class="border rounded p-2">
      <input class="form-check-input" type="radio" name="cover_pick" value="__keep__" checked>
      {{ _("Keep current") }}
    </label>
    <label class="border rounded p-2">
      <input class="form-check-input" type="radio" name="cover_pick" value="__none__">
      {{ _("No cover") }}
    </label>
    {% for asset in assets %}
    <label class="border rounded p-2{% if asset.id == current %} border-primary{% endif %}">
      <input class="form-check-input" type="radio" name="cover_pick" value="{{ asset.id }}">
      <img class="admin-thumb rounded border d-block my-1" src="/media-files/{{ asset.path }}" alt="" width="96" height="64" loading="lazy">
      {{ picker_tile_meta(asset, widest) }}
    </label>
    {% endfor %}
  </div>
</details>
{% endif %}
{% endmacro %}

{% macro media_adder(assets, existing, widest) %}
{% if assets %}
<details class="mb-2">
  <summary class="form-text">{{ _("Add from the library") }}</summary>
  <div class="d-flex flex-wrap gap-2 mt-2">
    {% for asset in assets if asset.id not in existing %}
    <label class="border rounded p-2">
      <input class="form-check-input" type="checkbox" name="media_add" value="{{ asset.id }}">
      <img class="admin-thumb rounded border d-block my-1" src="/media-files/{{ asset.path }}" alt="" width="96" height="64" loading="lazy">
      {{ picker_tile_meta(asset, widest) }}
    </label>
    {% else %}
    <span class="form-text">{{ _("Every library image is already in this section.") }}</span>
    {% endfor %}
  </div>
</details>
{% endif %}
{% endmacro %}

{% macro metadata_fields(form) %}
{{ text_field("category", _("Category"), form.category, hint=_("a category slug, or empty")) }}
{{ text_field("tags", _("Tags"), form.tags, hint=_("comma-separated slugs")) }}
{{ text_field("cover", _("Cover"), form.cover, hint=_("a media asset id, or empty")) }}
{{ cover_picker(image_assets | default([]), form.cover, picker_widest | default(0)) }}
{{ text_field("author", _("Author"), form.author, hint=_("editorial byline; empty shows the site name")) }}
<div class="mb-1 form-check admin-field">
  <input class="form-check-input" type="checkbox" id="featured" name="featured" value="1"
         {% if form.featured %}checked{% endif %}>
  <label class="form-check-label" for="featured">{{ _("Featured") }}</label>
  <div class="form-text admin-hint">{{ _("featured articles lead the home highlight") }}</div>
</div>
{{ datetime_field("publish_at", _("Publish at (UTC)"), form.publish_at,
                  hint=_("empty publishes immediately once published; a future moment keeps the entry out of builds until a build runs after it")) }}
{{ datetime_field("unpublish_at", _("Unpublish at (UTC)"), form.unpublish_at,
                  hint=_("optional end of the window — after this moment the next build drops the entry; must fall after the publish moment")) }}
{% endmacro %}

{% macro errors_block(errors) %}
{% if errors %}
<div class="alert alert-danger admin-alert" role="alert">
  <p class="mb-1">{{ _("The form was not saved:") }}</p>
  <ul class="mb-0">{% for error in errors %}<li>{{ _(error) }}</li>{% endfor %}</ul>
</div>
{% endif %}
{% endmacro %}

{% macro state_badge(state) %}
{% set tone = {"complete": "text-bg-success", "outdated": "text-bg-warning", "missing": "text-bg-danger"}[state.value] %}
<span class="badge {{ tone }} admin-state admin-state-{{ state.value }}">{{ _(state.value) }}</span>
{% endmacro %}

{% macro status_tag(status) %}
{% set tone = {"draft": "text-bg-secondary", "review": "text-bg-warning", "published": "text-bg-success", "archived": "text-bg-dark"}[status.value] %}
<span class="badge {{ tone }} admin-tag admin-tag-{{ status.value }}">{{ _(status.value) }}</span>
{% endmacro %}

{% macro translation_badges(entry, target_languages, base_url=None) %}
{# Constant-width coverage for list rows (ADR-0034 invariant: language
   sets are unbounded — lists must never grow horizontally per
   language). The aggregate is the cell; the per-language detail lives
   in the editor. State is in text and title, never color alone. #}
{% set ns = namespace(complete=0, missing=0, outdated=0) %}
{% for language in target_languages %}
{% set state = entry.translation_state(language) %}
{% if state.value == "complete" %}{% set ns.complete = ns.complete + 1 %}
{% elif state.value == "missing" %}{% set ns.missing = ns.missing + 1 %}
{% else %}{% set ns.outdated = ns.outdated + 1 %}{% endif %}
{% endfor %}
{% set complete = ns.complete %}{% set missing = ns.missing %}{% set outdated = ns.outdated %}
{% set total = target_languages | length %}
{% set tone = "text-bg-success" if complete == total else ("text-bg-danger" if missing else "text-bg-warning") %}
{% set detail = [] %}
{% if missing %}{% set discard = detail.append(missing ~ " " ~ _("missing")) %}{% endif %}
{% if outdated %}{% set discard = detail.append(outdated ~ " " ~ _("outdated")) %}{% endif %}
{% set summary = complete ~ "/" ~ total %}
{% set label = summary if not detail else summary ~ " · " ~ detail | join(" · ") %}
{% if base_url %}
<a href="{{ base_url }}" class="badge {{ tone }} admin-coverage text-decoration-none"
   title="{{ _("Translations") }}: {{ label }}">{{ label }}</a>
{% else %}
<span class="badge {{ tone }} admin-coverage" title="{{ _("Translations") }}: {{ label }}">{{ label }}</span>
{% endif %}
{% endmacro %}

{% macro row_actions(kind, entity_id, transitions) %}
{# List quick actions (M5): the workflow transitions and trash for this
   row, in a Bootstrap dropdown — no editor round-trip. #}
<div class="dropdown">
  <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
          data-bs-toggle="dropdown" aria-expanded="false"
          aria-label="{{ _('Actions for %(id)s') | format(id=entity_id) }}">
    <i class="bi bi-three-dots" aria-hidden="true"></i>
  </button>
  <ul class="dropdown-menu dropdown-menu-end">
    {% for t in transitions %}
    <li>
      <form method="post" action="/{{ kind }}s/{{ entity_id }}/status" class="mb-0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="to" value="{{ t.to }}">
        <button type="submit" class="dropdown-item">{{ _(t.label) }}</button>
      </form>
    </li>
    {% endfor %}
    {% if transitions %}<li><hr class="dropdown-divider"></li>{% endif %}
    <li>
      <form method="post" action="/trash/{{ kind }}/{{ entity_id }}" class="mb-0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="dropdown-item text-danger">{{ _("Move to trash") }}</button>
      </form>
    </li>
  </ul>
</div>
{% endmacro %}

{% macro seo_fields(form, image_assets=[]) %}
<details class="mb-2"{% if form.seo_title or form.seo_description or form.noindex or form.canonical or form.og_image %} open{% endif %}>
  <summary class="form-text">{{ _("Search and social (optional)") }}</summary>
  <div class="mt-2">
    {{ text_field("seo_title", _("SEO title"), form.seo_title, hint=_("overrides the page title for search and social; empty derives from the content")) }}
    {{ text_field("seo_description", _("SEO description"), form.seo_description, hint=_("the snippet under the title; empty derives from the summary")) }}
    <div class="mb-1 form-check admin-field">
      <input class="form-check-input" type="checkbox" id="noindex" name="noindex" value="1"
             {% if form.noindex %}checked{% endif %}>
      <label class="form-check-label" for="noindex">{{ _("Ask search engines not to index this entry") }}</label>
    </div>
    {{ text_field("canonical", _("Canonical URL"), form.canonical, hint=_("only when this content originally lives at another address")) }}
    {{ text_field("og_image", _("Social image"), form.og_image, hint=_("a media asset id; the published rendition becomes the card image")) }}
    <div class="card admin-social-preview" aria-hidden="true">
      <div class="card-body py-2">
        <span class="form-text d-block">{{ _("Preview") }}</span>
        <strong class="d-block">{{ form.seo_title or form.title }}</strong>
        <span class="d-block">{{ form.seo_description or form.summary or form.description or "" }}</span>
      </div>
    </div>
  </div>
</details>
{% endmacro %}

{% macro preview_links_card(kind, entry_id, links, csrf_token) %}
<div class="card mb-3">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("External preview links") }}</h2></div>
  <div class="card-body">
    <form method="post" action="/{{ kind }}s/{{ entry_id }}/preview-links" class="d-flex flex-wrap gap-2 align-items-end mb-2">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <label class="mb-0">
        <span class="form-text d-block">{{ _("Valid for (days)") }}</span>
        <input class="form-control admin-input" type="number" name="days" value="7" min="1" max="30">
      </label>
      <button type="submit" class="btn btn-outline-primary btn-sm">{{ _("Create preview link") }}</button>
      <span class="form-text mb-0">{{ _("Anyone with the link sees a draft banner; publication never changes.") }}</span>
    </form>
    {% if links %}
    <ul class="list-group list-group-flush">
      {% for link in links %}
      <li class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span class="flex-grow-1"><input class="form-control admin-input" readonly value="{{ link.url }}" aria-label="{{ _("External preview links") }}"></span>
        <span class="form-text mb-0">{{ link.expires_at.strftime("%Y-%m-%d %H:%M") }} UTC</span>
        <form method="post" action="/preview-links/{{ link.id }}/revoke" class="mb-0">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="btn btn-outline-danger btn-sm">{{ _("Revoke") }}</button>
        </form>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="admin-empty mb-0">{{ _("No active preview links.") }}</p>
    {% endif %}
  </div>
</div>
{% endmacro %}
