{% extends "shell.html.j2" %}
{% block title %}{{ _("Media") }} — Sardine CMS admin{% endblock %}
{% block header %}
<div class="d-flex justify-content-between align-items-center">
  <h1 class="h3 mb-0">{{ _("Media") }}</h1>
  <a class="btn btn-primary" href="/media/new">{{ _("Upload media") }}</a>
</div>
{% endblock %}
{% block content %}
<form method="get" action="/media" class="card mb-3">
  <div class="card-body d-flex flex-wrap gap-2 align-items-end">
    <div class="admin-field">
      <label class="form-label mb-1" for="media-q">{{ _("Search") }}</label>
      <input class="form-control form-control-sm admin-input" id="media-q" name="q"
             value="{{ q }}" placeholder="{{ _("id, path, type or alt text") }}">
    </div>
    <div class="admin-field">
      <label class="form-label mb-1" for="media-show">{{ _("Show") }}</label>
      <select class="form-select form-select-sm" id="media-show" name="show">
        <option value="all" {% if show == "all" %}selected{% endif %}>{{ _("Everything") }}</option>
        <option value="images" {% if show == "images" %}selected{% endif %}>{{ _("Images only") }}</option>
        <option value="missing-alt" {% if show == "missing-alt" %}selected{% endif %}>{{ _("Missing translated alt") }}</option>
      </select>
    </div>
    <button type="submit" class="btn btn-outline-secondary btn-sm">{{ _("Filter") }}</button>
    {% if q or show != "all" %}
    <a class="btn btn-link btn-sm" href="/media">{{ _("Clear") }}</a>
    <span class="form-text mb-1">{{ _("%(shown)s of %(total)s assets") | format(shown=assets | length, total=total) }}</span>
    {% endif %}
  </div>
</form>
{% if assets %}
<div class="card">
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped table-hover align-middle mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col"><span class="visually-hidden">{{ _("Select") }}</span></th>
          <th scope="col">{{ _("Preview") }}</th>
          <th scope="col">{{ _("ID") }}</th>
          <th scope="col">{{ _("Type") }}</th>
          <th scope="col">{{ _("Size") }}</th>
          <th scope="col">{{ _("Alt (EN)") }}</th>
          <th scope="col">{{ _("Translated alt") }}</th>
        </tr>
      </thead>
      <tbody>
        {% for asset in assets %}
        <tr>
          <td>{% if asset.is_image %}<img class="admin-thumb rounded border" src="/media-files/{{ asset.path }}"
                alt="" width="72" height="48" loading="lazy">{% endif %}</td>
          <td><label class="mb-0"><span class="visually-hidden admin-visually-hidden">{{ _("Select %(id)s") | format(id=asset.id) }}</span>
            <input class="form-check-input" type="checkbox" name="selected" value="{{ asset.id }}" form="bulk-form"></label></td>
          <th scope="row"><a href="/media/{{ asset.id }}">{{ asset.id }}</a></th>
          <td>{{ asset.mime_type }}</td>
          <td>{% if asset.width %}{{ asset.width }}×{{ asset.height }}{% endif %}</td>
          <td>{{ asset.alt.get(source_language, "") }}</td>
          <td>
            {% set missing = asset.missing_alt_languages() %}
            {% if missing %}
            <span class="badge text-bg-danger admin-state admin-state-missing">{{ missing | map(attribute="value") | join(", ") }}</span>
            {% else %}
            <span class="badge text-bg-success admin-state admin-state-complete">{{ _("complete") }}</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
<form method="post" action="/media/bulk" id="bulk-form" class="card mt-3">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card-body d-flex flex-wrap gap-2 align-items-center">
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Bulk action") }}</span>
      <select class="form-select admin-input" name="action">
        <option value="delete">{{ _("Delete unreferenced") }}</option>
      </select>
    </label>
    <button type="submit" class="btn btn-outline-danger">{{ _("Apply to selected") }}</button>
    <span class="form-text mb-0">{{ _("Referenced assets refuse deletion — the report says which.") }}</span>
  </div>
</form>
{% else %}
{% if q or show != "all" %}
<p class="admin-empty">{{ _("Nothing matches the filter.") }}</p>
{% else %}
<p class="admin-empty">{{ _("No media yet — upload the first asset.") }}</p>
{% endif %}
{% endif %}
{% endblock %}
