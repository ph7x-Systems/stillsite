{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import translation_badges, status_tag, row_actions with context %}
{% block title %}{{ _("Articles") }} — Sardine CMS admin{% endblock %}
{% block header %}
<div class="d-flex justify-content-between align-items-center">
  <h1 class="h3 mb-0">{{ _("Articles") }}</h1>
  <a class="btn btn-primary" href="/articles/new">{{ _("New article") }}</a>
</div>
{% endblock %}
{% block content %}
{% if target_languages %}
<form method="get" action="/articles" class="mb-3 d-flex gap-2 align-items-center">
  <label class="mb-0">
    <span class="visually-hidden admin-visually-hidden">{{ _("Needs translation into") }}</span>
    <select class="form-select form-select-sm admin-input" name="needs">
      <option value="">{{ _("Every entry") }}</option>
      {% for target in target_languages %}
      <option value="{{ target }}" {% if needs == target | string %}selected{% endif %}>
        {{ _("missing %(tag)s") | format(tag=target | upper) }}</option>
      {% endfor %}
    </select>
  </label>
  <button type="submit" class="btn btn-outline-secondary btn-sm">{{ _("Filter") }}</button>
</form>
{% endif %}
{% if articles %}
<div class="card">
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped table-hover mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col"><span class="visually-hidden">{{ _("Select") }}</span></th>
          <th scope="col">{{ _("ID") }}</th>
          <th scope="col">{{ _("Title (EN)") }}</th>
          <th scope="col">{{ _("Status") }}</th>
          <th scope="col">{{ _("Translations") }}</th>
          <th scope="col">{{ _("Updated") }}</th>
          <th scope="col"><span class="visually-hidden">{{ _("Actions") }}</span></th>
        </tr>
      </thead>
      <tbody>
        {% for article in articles %}
        <tr>
          <td><label class="mb-0"><span class="visually-hidden admin-visually-hidden">{{ _("Select %(id)s") | format(id=article.id) }}</span>
            <input class="form-check-input" type="checkbox" name="selected" value="{{ article.id }}" form="bulk-form"></label></td>
          <th scope="row"><a href="/articles/{{ article.id }}">{{ article.id }}</a></th>
          <td>{{ article.source.title }}</td>
          <td>{{ status_tag(article.status) }}</td>
          <td>{{ translation_badges(article, target_languages, "/articles/" + article.id) }}</td>
          <td>{{ article.updated_at.strftime("%Y-%m-%d") }}</td>
          <td>{{ row_actions("article", article.id, row_actions_map[article.id]) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
<form method="post" action="/articles/bulk" id="bulk-form" class="card mt-3">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card-body d-flex flex-wrap gap-2 align-items-center">
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Bulk action") }}</span>
      <select class="form-select admin-input" name="action">
        <option value="to-review">{{ _("Submit for review") }}</option>
        <option value="to-draft">{{ _("Send back to draft") }}</option>
        <option value="publish">{{ _("Publish") }}</option>
        <option value="archive">{{ _("Archive") }}</option>
        <option value="trash">{{ _("Move to trash") }}</option>
        <option value="set-category">{{ _("Set category") }}</option>
      </select>
    </label>
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Category") }}</span>
      <input class="form-control admin-input" name="category" placeholder="{{ _('category (for Set category)') }}">
    </label>
    <button type="submit" class="btn btn-outline-primary">{{ _("Apply to selected") }}</button>
    <span class="form-text mb-0">{{ _("Each entry keeps its own rules — the report shows every outcome.") }}</span>
  </div>
</form>
{% else %}
<p class="admin-empty">{{ _("No articles yet — create the first one.") }}</p>
{% endif %}
{% endblock %}
