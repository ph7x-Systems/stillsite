{% extends "shell.html.j2" %}
{% block title %}{{ _("Themes") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Themes") }}</h1>{% endblock %}
{% block content %}

{% if activated %}
<div class="alert alert-success" role="status">
  {{ _("Activated %(name)s — the change applies to the next build and preview.") | format(name=activated) }}
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger" role="alert">
  {{ _("Activation failed and the configuration was left untouched: %(error)s") | format(error=error) }}
</div>
{% endif %}
{% if active_error %}
<div class="alert alert-warning" role="alert">
  {{ _("The active theme fails to load: %(error)s") | format(error=active_error) }}
</div>
{% endif %}

<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Installed themes") }}</h2></div>
  {% if not has_project %}
  <div class="card-body"><p class="admin-empty mb-0">{{ _("No project configuration was found; themes activate per project.") }}</p></div>
  {% else %}
  <div class="card-body">
    <p class="mb-0">{{ _("Themes install with the environment's package manager and appear here on their own. Activation tries a full build first — a failing theme never reaches the configuration.") }}</p>
  </div>
  <div class="card-body border-top">
    <div class="row g-3">
      {% for theme in themes %}
      <div class="col-md-6 col-xl-4 d-flex">
        <div class="card w-100">
          {% if theme.screenshot %}
          <img src="/themes/screenshot/{{ theme.name }}" class="card-img-top admin-theme-shot" width="1280" height="800"
               alt="{{ _("Screenshot of the %(name)s theme") | format(name=theme.name) }}">
          {% endif %}
          <div class="card-body">
            <h3 class="h6 mb-1">{{ theme.name }}
              {% if theme.version %}<small class="text-body-secondary">{{ theme.version }}</small>{% endif %}
              {% if theme.name == active %}
              <span class="badge text-bg-success admin-state admin-state-complete">{{ _("Active") }}</span>
              {% endif %}
            </h3>
            {% if theme.description %}<p class="mb-2">{{ theme.description }}</p>{% endif %}
            <ul class="list-unstyled mb-2 small text-body-secondary">
              <li>{{ theme.distribution or _("Built-in") }}</li>
              {% if theme.author %}<li>{{ _("By %(author)s") | format(author=theme.author) }}</li>{% endif %}
              {% if theme.license %}<li>{{ _("License: %(license)s") | format(license=theme.license) }}</li>{% endif %}
              {% if theme.homepage %}<li><a href="{{ theme.homepage }}">{{ _("Website") }}</a></li>{% endif %}
              {% if theme.compatible is true %}<li>{{ _("Compatible with this installation") }}</li>
              {% elif theme.compatible is false %}<li class="text-danger">{{ _("Not compatible with this installation") }}</li>{% endif %}
            </ul>
            {% if theme.name != active %}
            <form method="post" action="/themes/activate">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="name" value="{{ theme.name }}">
              <button type="submit" class="btn btn-sm btn-outline-primary"
                      {% if theme.compatible is false %}disabled{% endif %}>{{ _("Activate") }}</button>
            </form>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>
{% endblock %}
