{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import textarea_field, errors_block, state_badge with context %}
{% block title %}{{ page.id }} · {{ section.key }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/pages/{{ page.id }}">&larr; {{ page.id }}</a></nav>
<h1 class="h3 mb-0">{{ section.key }} <span class="badge text-bg-light border admin-tag">{{ section.kind }}</span></h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
<form method="post" action="/pages/{{ page.id }}/sections/{{ section.key }}" class="admin-form">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Fields (source)") }}</h2></div>
    <div class="card-body">
      <p class="form-text">{{ _("Free-form name/value pairs the theme's") }}
        <code>{{ section.kind }}</code> {{ _("template consumes. Clear a value to drop its field; use the blank rows to add more.") }}</p>
      <div class="table-responsive admin-table-wrap">
        <table class="table table-sm mb-0 admin-table">
          <thead><tr><th scope="col">{{ _("Field") }}</th><th scope="col">{{ _("Value") }}</th></tr></thead>
          <tbody>
            {% for row in rows %}
            <tr>
              <td><label class="mb-0 w-100">
                <span class="visually-hidden admin-visually-hidden">{{ _("Field name") }}</span>
                <input class="form-control form-control-sm admin-input" name="field_name" value="{{ row.name }}"></label></td>
              <td><label class="mb-0 w-100">
                <span class="visually-hidden admin-visually-hidden">{{ _("Field value") }}</span>
                <input class="form-control form-control-sm admin-input admin-field-value" name="field_value"
                       value="{{ row.value }}"></label></td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {% if markdown_fields %}
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Markdown fields") }}</h2></div>
    <div class="card-body">
      {% for name, value in markdown_fields %}
      {{ textarea_field("md_" ~ name, name, value, rows=6, markdown=true) }}
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if item_columns %}
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Items") }}</h2></div>
    <div class="card-body">
      <p class="form-text">{{ _("One row per item — clear a whole row to remove it.") }}</p>
      <div class="table-responsive admin-table-wrap">
        <table class="table table-sm mb-0 admin-table">
          <thead><tr>{% for column in item_columns %}<th scope="col">{{ column }}</th>{% endfor %}</tr></thead>
          <tbody>
            {% for row in item_rows %}
            <tr>
              {% for column in item_columns %}
              <td><label class="mb-0 w-100">
                <span class="visually-hidden admin-visually-hidden">{{ column }}</span>
                <input class="form-control form-control-sm admin-input" name="item_{{ column }}"
                       value="{{ row[loop.index0] }}"></label></td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {% endif %}
  <div class="card mb-3"><div class="card-body">
    {{ textarea_field("media", _("Media asset IDs (one per line)"), media_text, rows=3) }}
  </div></div>
  <button type="submit" class="btn btn-primary mb-3">{{ _("Save section") }}</button>
</form>
<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Translations") }}</h2></div>
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped mb-0 admin-table">
      <thead><tr><th scope="col">{{ _("Language") }}</th><th scope="col">{{ _("State") }}</th><th scope="col"></th></tr></thead>
      <tbody>
        {% for language in target_languages %}
        <tr>
          <th scope="row">{{ language.value | upper }}</th>
          <td>{{ state_badge(states[language]) }}</td>
          <td><a href="/pages/{{ page.id }}/sections/{{ section.key }}/translations/{{ language.value }}">
            {{ _("Edit translation") }}</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
