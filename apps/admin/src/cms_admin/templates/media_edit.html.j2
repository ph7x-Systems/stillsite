{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import errors_block with context %}
{% block title %}{{ asset.id }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/media">&larr; {{ _("Media") }}</a></nav>
<h1 class="h3 mb-0">{{ asset.id }} <span class="badge text-bg-light border admin-tag">{{ asset.mime_type }}</span></h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Preview") }}</h2></div>
      <div class="card-body">
        {% if asset.is_image %}
        <div class="admin-preview admin-media-preview mb-3">
          <img src="/media-files/{{ asset.path }}" alt="{{ asset.alt.values() | list | first }}"
               width="{{ asset.width }}" height="{{ asset.height }}" class="img-fluid rounded border">
        </div>
        {% endif %}
        <dl class="admin-source">
          <dt>{{ _("Path") }}</dt><dd><code>{{ asset.path }}</code></dd>
          {% if asset.width %}<dt>{{ _("Dimensions") }}</dt><dd>{{ asset.width }}×{{ asset.height }}</dd>{% endif %}
        </dl>
        <h3 class="h6">{{ _("Used by") }}</h3>
        {% if references %}
        <ul>{% for reference in references %}<li><code>{{ reference }}</code></li>{% endfor %}</ul>
        <p class="form-text">{{ _("Referenced assets cannot be deleted.") }}</p>
        {% else %}
        <p class="admin-empty">{{ _("Nothing references this asset.") }}</p>
        <form method="post" action="/media/{{ asset.id }}/delete" class="mb-0">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="btn btn-outline-danger">{{ _("Delete asset") }}</button>
        </form>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <form method="post" action="/media/{{ asset.id }}" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Alt text") }}</h2></div>
        <div class="card-body">
          <div class="mb-1 admin-field">
            <label class="form-label" for="alt_en">{{ _("EN (mandatory)") }}</label>
            <input class="form-control admin-input" id="alt_en" name="alt_en" value="{{ form.alt_en }}" required>
          </div>
          {% for language in target_languages %}
          <div class="mb-1 admin-field">
            <label class="form-label" for="alt_{{ language.value }}">{{ language.value | upper }}</label>
            <input class="form-control admin-input" id="alt_{{ language.value }}"
                   name="alt_{{ language.value }}" value="{{ form["alt_" + language.value] }}">
          </div>
          {% endfor %}
        </div>
      </div>
      <button type="submit" class="btn btn-primary">{{ _("Save alt text") }}</button>
    </form>
  </div>
</div>
{% endblock %}
