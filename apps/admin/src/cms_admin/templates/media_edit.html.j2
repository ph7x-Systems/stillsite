{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import errors_block with context %}
{% block title %}{{ asset.id }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/media">&larr; {{ _("Media") }}</a></nav>
<h1 class="h3 mb-0">{{ asset.id }} <span class="badge text-bg-light border admin-tag">{{ asset.mime_type }}</span></h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Preview") }}</h2></div>
      <div class="card-body">
        {% if asset.is_image %}
        <div class="admin-preview admin-media-preview mb-3">
          <img src="/media-files/{{ asset.path }}" alt="{{ asset.alt.values() | list | first }}"
               width="{{ asset.width }}" height="{{ asset.height }}" class="img-fluid rounded border">
        </div>
        {% endif %}
        <dl class="admin-source">
          <dt>{{ _("Path") }}</dt><dd><code>{{ asset.path }}</code></dd>
          {% if asset.width %}<dt>{{ _("Dimensions") }}</dt><dd>{{ asset.width }}×{{ asset.height }}</dd>{% endif %}
          {% if asset.collection %}<dt>{{ _("Collection") }}</dt><dd><a href="/media?collection={{ asset.collection }}">{{ asset.collection }}</a></dd>{% endif %}
        </dl>
        <form method="post" action="/media/{{ asset.id }}/replace" enctype="multipart/form-data" class="mb-3">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <div class="mb-1 admin-field">
            <label class="form-label" for="replace-upload">{{ _("Replace file") }}</label>
            <input class="form-control admin-input" id="replace-upload" name="upload" type="file"
                   accept=".png,.jpg,.jpeg,.gif,.webp" required>
            <div class="form-text admin-hint">{{ _("the asset keeps its ID — every reference stays valid; the new file goes live on the next publish") }}</div>
          </div>
          <button type="submit" class="btn btn-outline-secondary btn-sm">{{ _("Replace") }}</button>
        </form>
        <h3 class="h6">{{ _("Used by") }}</h3>
        {% if references %}
        <ul>{% for reference in references %}<li><code>{{ reference }}</code></li>{% endfor %}</ul>
        <p class="form-text">{{ _("Referenced assets cannot be deleted.") }}</p>
        {% else %}
        <p class="admin-empty">{{ _("Nothing references this asset.") }}</p>
        <form method="post" action="/media/{{ asset.id }}/delete" class="mb-0">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="btn btn-outline-danger">{{ _("Delete asset") }}</button>
        </form>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <form method="post" action="/media/{{ asset.id }}" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Alt text") }}</h2></div>
        <div class="card-body">
          <div class="mb-1 admin-field">
            <label class="form-label" for="alt_en">{{ _("EN (mandatory)") }}</label>
            <input class="form-control admin-input" id="alt_en" name="alt_en" value="{{ form.alt_en }}" required>
          </div>
          {% for language in target_languages %}
          <div class="mb-1 admin-field">
            <label class="form-label" for="alt_{{ language.value }}">{{ language.value | upper }}</label>
            <input class="form-control admin-input" id="alt_{{ language.value }}"
                   name="alt_{{ language.value }}" value="{{ form["alt_" + language.value] }}">
          </div>
          {% endfor %}
        </div>
      </div>
      {% if asset.is_image %}
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Crop and focal point") }}</h2></div>
        <div class="card-body">
          <div class="mb-1 admin-field">
            <label class="form-label" for="crop">{{ _("Crop") }}</label>
            <input class="form-control admin-input" id="crop" name="crop" value="{{ form.crop }}"
                   placeholder="x,y,width,height">
            <div class="form-text admin-hint">{{ _("pixels of the original, applied at build — empty shows the full image") }}</div>
          </div>
          <div class="mb-1 admin-field">
            <label class="form-label" for="focal">{{ _("Focal point") }}</label>
            <input class="form-control admin-input" id="focal" name="focal" value="{{ form.focal }}"
                   placeholder="0.5,0.5">
            <div class="form-text admin-hint">{{ _("fractions from the top-left, 0 to 1 — kept in view when the image is trimmed to fit") }}</div>
          </div>
        </div>
      </div>
      {% endif %}
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Collection") }}</h2></div>
        <div class="card-body">
          <div class="mb-1 admin-field">
            <label class="form-label" for="collection">{{ _("Collection") }}</label>
            <input class="form-control admin-input" id="collection" name="collection" value="{{ form.collection }}">
            <div class="form-text admin-hint">{{ _("optional folder, lowercase-with-dashes — group related assets") }}</div>
          </div>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">{{ _("Save alt text") }}</button>
    </form>
  </div>
</div>
{% endblock %}
