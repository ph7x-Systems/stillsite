{% extends "base.html.j2" %}
{% block title %}{{ _("Set the new password") }} — Sardine CMS admin{% endblock %}
{% block bodyclass %}login-page bg-body-secondary{% endblock %}
{% block body %}
<main id="main" class="login-box">
  <div class="card card-outline card-primary admin-login">
    <div class="card-header text-center">
      <img src="/static/brand/sardine.svg" alt="" width="56" height="56" class="mb-2">
      <span class="h4 d-block">Sardine CMS <small class="text-body-secondary">admin</small></span>
    </div>
    <div class="card-body">
      <h1 class="login-box-msg h5">{{ _("Set the new password") }}</h1>
      {% if error %}<p role="alert" class="alert alert-danger admin-alert">{{ _(error) }}</p>{% endif %}
      <form method="post" action="/reset/{{ token | urlencode }}">
        <input type="hidden" name="login_csrf" value="{{ login_csrf }}">
        <div class="mb-3 admin-field">
          <label class="form-label" for="password">{{ _("New password") }}</label>
          <input class="form-control admin-input" id="password" name="password" type="password"
                 autocomplete="new-password" required minlength="12">
        </div>
        <div class="mb-3 admin-field">
          <label class="form-label" for="password_repeat">{{ _("Repeat the new password") }}</label>
          <input class="form-control admin-input" id="password_repeat" name="password_repeat"
                 type="password" autocomplete="new-password" required minlength="12">
        </div>
        <button type="submit" class="btn btn-primary w-100">{{ _("Set the new password") }}</button>
      </form>
      <p class="mt-3 mb-0 text-center"><a href="/login">{{ _("Back to sign in") }}</a></p>
    </div>
  </div>
</main>
{% endblock %}
