{% extends "shell.html.j2" %}
{% block title %}{{ _("Publishing") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Publishing") }}</h1>{% endblock %}
{% block content %}
{% if not project %}
<div class="alert alert-danger admin-alert" role="alert">
  {{ _("No") }} <code>sardine.toml</code> {{ _("found in") }} <code>{{ project_dir }}</code> — {{ _("point") }}
  <code>SARDINE_PROJECT_DIR</code> {{ _("at the project directory to build from the panel.") }}
</div>
{% else %}
<p><strong>{{ project.site.name }}</strong> · {{ project.site.base_url }} ·
  {{ _("theme") }} <code>{{ project.site.theme }}</code> · {{ _("output") }} <code>{{ project.output }}</code></p>
{% endif %}
{% include "_validation_report.html.j2" %}
{% if deploy_state %}
<div class="card mb-3">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Public site") }}</h2></div>
  <div class="card-body">
    <p class="mb-2">
      {% if deploy_state.status == "active" %}
      <span class="badge text-bg-success admin-state admin-state-complete">{{ _("active") }}</span>
      {% elif deploy_state.status == "never-deployed" %}
      <span class="badge text-bg-secondary">{{ _("never deployed") }}</span>
      {% elif deploy_state.status == "rolled-back" %}
      <span class="badge text-bg-warning admin-state admin-state-outdated">{{ _("rolled back") }}</span>
      {% else %}
      <span class="badge text-bg-danger admin-state admin-state-missing">{{ _("failed") }}</span>
      {% endif %}
      {% if deploy_state.release_id %}<code>{{ deploy_state.release_id }}</code>{% endif %}
      {% if deploy_state.at %}<span class="form-text">{{ deploy_state.at }} · {{ deploy_state.actor }}</span>{% endif %}
    </p>
    {% if deploy_state.error %}
    <p class="alert alert-danger admin-alert mb-2">{{ deploy_state.error }}
      {% if deploy_state.phase %}<span class="form-text d-block">{{ _("phase") }}: {{ deploy_state.phase }}</span>{% endif %}</p>
    {% endif %}
    <div class="d-flex flex-wrap gap-2 align-items-center">
      <form method="post" action="/publishing/deploy" class="mb-0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="btn btn-primary">
          {% if deploy_state.status in ("failed", "rolled-back") %}{{ _("Retry deployment") }}{% else %}{{ _("Publish site now") }}{% endif %}
        </button>
      </form>
      <span class="form-text mb-0">{{ _("Publishing and unpublishing content redeploys automatically; this button forces a fresh release.") }}</span>
    </div>
    {% if deploy_state.releases %}
    <details class="mt-3">
      <summary class="form-text">{{ _("Kept releases (rollback needs no rebuild)") }}</summary>
      <ul class="list-group list-group-flush mt-2">
        {% for release in deploy_state.releases %}
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <span><code>{{ release.release_id }}</code>
            {% if release.active %}<span class="badge text-bg-success">{{ _("active") }}</span>{% endif %}
            <span class="form-text">{{ release.at }} · {{ release.actor }}</span></span>
          {% if not release.active %}
          <form method="post" action="/publishing/rollback" class="mb-0">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="release_id" value="{{ release.release_id }}">
            <button type="submit" class="btn btn-outline-warning btn-sm">{{ _("Roll back to this release") }}</button>
          </form>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endif %}
  </div>
</div>
{% endif %}
<div class="row">
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Run") }}</h2></div>
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2 align-items-center admin-runrow">
          <form method="post" action="/publishing/preview" class="mb-0">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-outline-secondary">{{ _("Preview build") }}</button>
          </form>
          <form method="post" action="/publishing/build" class="mb-0 w-100" id="build-form">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            {% set target_meta = {
              "generic": (_("Any static host"), _("A plain folder of files — upload the output directory to any static host or shared hosting.")),
              "swa": (_("Azure Static Web Apps"), _("Includes staticwebapp.config.json with your redirects and headers — deploy the output with the SWA CLI or a GitHub Action.")),
              "nginx": (_("Your own nginx server"), _("Includes an nginx.conf snippet with redirects and caching — copy the output to the server and include the snippet.")),
            } %}
            <fieldset class="mb-2">
              <legend class="h6 fs-6">{{ _("Where will the site live?") }}</legend>
              <div class="row g-2">
                {% for target in targets %}
                {% set meta = target_meta.get(target, (target, "")) %}
                <div class="col-12">
                  <label class="card admin-block-card w-100 mb-0 {% if target == current_target %}border-primary{% endif %}">
                    <span class="card-body d-flex gap-2 align-items-start py-2">
                      <input class="form-check-input mt-1" type="radio" name="target" value="{{ target }}"
                             {% if target == current_target %}checked{% endif %}>
                      <span>
                        <span class="d-block fw-semibold">{{ meta[0] }}</span>
                        <span class="d-block form-text">{{ meta[1] }}</span>
                      </span>
                    </span>
                  </label>
                </div>
                {% endfor %}
              </div>
              <p class="form-text mb-0 mt-1">{{ _("Your choice is remembered in the project — the cms command line uses it too.") }}</p>
            </fieldset>
            <button type="submit" class="btn btn-primary">{{ _("Build & export") }}</button>
          </form>
        </div>
        <p class="form-text mb-0 mt-2">{{ _("Preview writes to a temporary directory served at") }}
          <a href="/preview/">/preview/</a> {{ _("(any role). Build & export validates first, then writes the project's output directory with the target's extras — publisher role and up.") }}</p>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Last run") }}</h2></div>
      <div class="card-body">
        {% if last_build %}
        <dl class="mb-0 admin-source">
          <dt>{{ _("Kind") }}</dt><dd>{{ last_build.kind }}
            {% if last_build.ok %}<span class="badge text-bg-success admin-state admin-state-complete">{{ _("ok") }}</span>
            {% else %}<span class="badge text-bg-danger admin-state admin-state-missing">{{ _("failed") }}</span>{% endif %}</dd>
          <dt>{{ _("When") }}</dt><dd>{{ last_build.when }}</dd>
          {% if last_build.files %}<dt>{{ _("Files") }}</dt><dd>{{ last_build.files }}</dd>{% endif %}
          {% if last_build.digest %}<dt>{{ _("Digest") }}</dt><dd><code>{{ last_build.digest }}</code></dd>{% endif %}
          {% if last_build.detail %}<dt>{{ _("Detail") }}</dt><dd class="mb-0">{{ last_build.detail }}</dd>{% endif %}
        </dl>
        {% if last_build.ok and last_build.target %}
        <div class="alert alert-success mt-3 mb-0">
          <p class="fw-semibold mb-1">{{ _("Your site is built and ready to go live.") }}</p>
          <p class="mb-1">{{ _("The files are in") }} <code>{{ last_build.output }}</code>.</p>
          <p class="mb-0">
            {% if last_build.target == "swa" %}{{ _("Deploy that directory with the SWA CLI or your GitHub Action — the configuration file is already inside.") }}
            {% elif last_build.target == "nginx" %}{{ _("Copy that directory to your server and include the generated nginx.conf snippet.") }}
            {% else %}{{ _("Upload everything inside that directory to your host — that is the whole site.") }}{% endif %}
          </p>
        </div>
        {% endif %}
        {% else %}
        <p class="admin-empty mb-0">{{ _("Nothing has run from this panel yet.") }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
