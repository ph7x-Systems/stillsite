{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import state_badge with context %}
{% block title %}{{ _("Translations") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Translations") }}</h1>{% endblock %}
{% block content %}
<form method="get" action="/translations" class="card mb-3">
  <div class="card-body d-flex flex-wrap gap-2 align-items-center">
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Language") }}</span>
      <select class="form-select admin-input" name="language">
        <option value="">{{ _("Every language") }}</option>
        {% for target in targets %}
        <option value="{{ target }}" {% if language == target %}selected{% endif %}>{{ target | upper }}</option>
        {% endfor %}
      </select>
    </label>
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("State") }}</span>
      <select class="form-select admin-input" name="state">
        <option value="">{{ _("Missing and outdated") }}</option>
        <option value="missing" {% if state == "missing" %}selected{% endif %}>{{ _("missing") }}</option>
        <option value="outdated" {% if state == "outdated" %}selected{% endif %}>{{ _("outdated") }}</option>
      </select>
    </label>
    <label class="mb-0">
      <span class="visually-hidden admin-visually-hidden">{{ _("Type") }}</span>
      <select class="form-select admin-input" name="kind">
        <option value="">{{ _("Articles and pages") }}</option>
        <option value="article" {% if kind == "article" %}selected{% endif %}>{{ _("Articles") }}</option>
        <option value="page" {% if kind == "page" %}selected{% endif %}>{{ _("Pages") }}</option>
      </select>
    </label>
    <button type="submit" class="btn btn-outline-primary">{{ _("Filter") }}</button>
    <span class="form-text mb-0">{{ _("%(total)s pair(s) waiting overall") | format(total=total_pending) }}</span>
  </div>
</form>
{% if rows %}
<div class="card">
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-striped table-hover mb-0 admin-table">
      <thead>
        <tr>
          <th scope="col">{{ _("Language") }}</th>
          <th scope="col">{{ _("Type") }}</th>
          <th scope="col">{{ _("Entry") }}</th>
          <th scope="col">{{ _("State") }}</th>
          <th scope="col"><span class="visually-hidden">{{ _("Actions") }}</span></th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
        <tr>
          <th scope="row">{{ row.language | upper }}</th>
          <td>{% if row.kind == "article" %}{{ _("Article") }}{% else %}{{ _("Page") }}{% endif %}</td>
          <td><a href="/{{ row.kind }}s/{{ row.id }}">{{ row.title }}</a></td>
          <td><span class="badge {% if row.state == 'missing' %}text-bg-danger admin-state admin-state-missing{% else %}text-bg-warning admin-state admin-state-outdated{% endif %}">{{ _(row.state) }}</span></td>
          <td><a href="{{ row.url }}">{{ _("Translate") }}</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% else %}
<p class="admin-empty">{{ _("All caught up — every configured language is complete.") }}</p>
{% endif %}
{% endblock %}
