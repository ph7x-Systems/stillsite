{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import text_field, textarea_field, errors_block, state_badge with context %}
{% block title %}{{ page.id }} · {{ language.value | upper }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb"><a href="/pages/{{ page.id }}">&larr; {{ page.id }}</a></nav>
<h1 class="h3 mb-0">{{ page.id }} — {{ language.value | upper }} {{ state_badge(state) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
<div class="row admin-sbs">
  <div class="col-lg-6">
    <div class="card mb-3">
      <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Source (EN)") }}</h2></div>
      <div class="card-body">
        <dl class="mb-0 admin-source">
          <dt>{{ _("Title") }}</dt><dd>{{ page.source.title }}</dd>
          <dt>{{ _("Description") }}</dt><dd>{{ page.source.description }}</dd>
          <dt>{{ _("Slug") }}</dt><dd class="mb-0">{{ page.source.slug }}</dd>
        </dl>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <form method="post" action="/pages/{{ page.id }}/translations/{{ language.value }}"
          class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="card mb-3">
        <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Translation") }} ({{ language.value | upper }})</h2></div>
        <div class="card-body">
          {{ text_field("title", _("Title"), form.title, required=true) }}
          {{ textarea_field("description", _("Description"), form.description, rows=3) }}
          {{ text_field("slug", _("Slug"), form.slug, required=true) }}
        </div>
      </div>
      <button type="submit" class="btn btn-primary">{{ _("Save translation") }}</button>
    </form>
  </div>
</div>
{% endblock %}
