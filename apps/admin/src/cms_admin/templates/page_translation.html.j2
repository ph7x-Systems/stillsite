{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import text_field, textarea_field, errors_block, state_badge %}
{% block title %}{{ page.id }} · {{ language.value | upper }} — Stillsite admin{% endblock %}
{% block content %}
<nav aria-label="Breadcrumb"><a href="/pages/{{ page.id }}">&larr; {{ page.id }}</a></nav>
<h1>{{ page.id }} — {{ language.value | upper }} {{ state_badge(state) }}</h1>
{{ errors_block(errors) }}
<div class="admin-sbs">
  <section aria-labelledby="source-heading">
    <h2 id="source-heading">Source (EN)</h2>
    <dl class="admin-source">
      <dt>Title</dt><dd>{{ page.source.title }}</dd>
      <dt>Description</dt><dd>{{ page.source.description }}</dd>
      <dt>Slug</dt><dd>{{ page.source.slug }}</dd>
    </dl>
  </section>
  <form method="post" action="/pages/{{ page.id }}/translations/{{ language.value }}"
        class="admin-form">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <fieldset class="hoo-fieldset">
      <legend class="hoo-legend">Translation ({{ language.value | upper }})</legend>
      {{ text_field("title", "Title", form.title, required=true) }}
      {{ textarea_field("description", "Description", form.description, rows=3) }}
      {{ text_field("slug", "Slug", form.slug, required=true) }}
    </fieldset>
    <div>
      <button type="submit" class="hoo-button-primary">
        <span class="hoo-button-label">Save translation</span></button>
    </div>
  </form>
</div>
{% endblock %}
