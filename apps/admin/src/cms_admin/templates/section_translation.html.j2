{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import textarea_field, errors_block, state_badge %}
{% block title %}{{ page.id }} · {{ section.key }} · {{ language.value | upper }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb">
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">&larr; {{ section.key }}</a></nav>
<h1 class="h3 mb-0">{{ section.key }} — {{ language.value | upper }} {{ state_badge(state) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
{% if source_fields %}
<form method="post"
      action="/pages/{{ page.id }}/sections/{{ section.key }}/translations/{{ language.value }}"
      class="admin-form">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">Fields — source next to translation</h2></div>
    <div class="card-body p-0 admin-table-wrap">
      <table class="table table-striped mb-0 admin-table">
        <thead>
          <tr>
            <th scope="col">Field</th>
            <th scope="col">Source (EN)</th>
            <th scope="col">Translation ({{ language.value | upper }})</th>
          </tr>
        </thead>
        <tbody>
          {% for name, value in source_fields %}
          <tr>
            <th scope="row">{{ name }}</th>
            <td>{{ value }}</td>
            <td><label class="mb-0 w-100">
              <span class="visually-hidden admin-visually-hidden">{{ name }} translation</span>
              <input class="form-control form-control-sm admin-input admin-field-value" name="field__{{ name }}"
                     value="{{ form[name] }}"></label></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <div class="card mb-3"><div class="card-body">
    {{ textarea_field("media", "Media asset IDs (one per line)", media_text, rows=3) }}
  </div></div>
  <button type="submit" class="btn btn-primary">Save translation</button>
</form>
{% else %}
<p class="admin-empty">The source section has no fields yet — add them on the
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">section editor</a> first.</p>
{% endif %}
{% endblock %}
