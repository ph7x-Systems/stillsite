{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import textarea_field, errors_block, state_badge %}
{% block title %}{{ page.id }} · {{ section.key }} · {{ language.value | upper }} — Stillsite admin{% endblock %}
{% block content %}
<nav class="admin-breadcrumb" aria-label="Breadcrumb">
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">&larr; {{ section.key }}</a></nav>
<h1>{{ section.key }} — {{ language.value | upper }} {{ state_badge(state) }}</h1>
{{ errors_block(errors) }}
{% if source_fields %}
<form method="post"
      action="/pages/{{ page.id }}/sections/{{ section.key }}/translations/{{ language.value }}"
      class="admin-form">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <fieldset>
    <legend>Fields — source next to translation</legend>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Field</th>
            <th scope="col">Source (EN)</th>
            <th scope="col">Translation ({{ language.value | upper }})</th>
          </tr>
        </thead>
        <tbody>
          {% for name, value in source_fields %}
          <tr>
            <th scope="row">{{ name }}</th>
            <td>{{ value }}</td>
            <td><label>
              <span class="admin-visually-hidden">{{ name }} translation</span>
              <input class="admin-input admin-field-value" name="field__{{ name }}"
                     value="{{ form[name] }}"></label></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </fieldset>
  {{ textarea_field("media", "Media asset IDs (one per line)", media_text, rows=3) }}
  <div>
    <button type="submit" class="admin-btn admin-btn-primary">Save translation</button>
  </div>
</form>
{% else %}
<p class="admin-empty">The source section has no fields yet — add them on the
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">section editor</a> first.</p>
{% endif %}
{% endblock %}
