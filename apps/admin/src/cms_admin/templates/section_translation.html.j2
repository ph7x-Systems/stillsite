{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import textarea_field, errors_block, state_badge with context %}
{% block title %}{{ page.id }} · {{ section.key }} · {{ language.value | upper }} — Sardine CMS admin{% endblock %}
{% block header %}
<nav aria-label="Breadcrumb" class="admin-breadcrumb">
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">&larr; {{ section.key }}</a></nav>
<h1 class="h3 mb-0">{{ section.key }} — {{ language.value | upper }} {{ state_badge(state) }}</h1>
{% endblock %}
{% block content %}
{{ errors_block(errors) }}
{% if source_fields or markdown_fields or item_pairs %}
<form method="post"
      action="/pages/{{ page.id }}/sections/{{ section.key }}/translations/{{ language.value }}"
      class="admin-form">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Fields — source next to translation") }}</h2></div>
    <div class="card-body p-0 table-responsive admin-table-wrap">
      <table class="table table-striped mb-0 admin-table">
        <thead>
          <tr>
            <th scope="col">{{ _("Field") }}</th>
            <th scope="col">{{ _("Source") }}</th>
            <th scope="col">{{ _("Translation") }} ({{ language.value | upper }})</th>
          </tr>
        </thead>
        <tbody>
          {% for name, value in source_fields %}
          <tr>
            <th scope="row">{{ name }}</th>
            <td>{{ value }}</td>
            <td><label class="mb-0 w-100">
              <span class="visually-hidden admin-visually-hidden">{{ _("%(name)s translation") | format(name=name) }}</span>
              <input class="form-control form-control-sm admin-input admin-field-value" name="field__{{ name }}"
                     value="{{ form[name] }}"></label></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% if markdown_fields %}
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Markdown fields") }}</h2></div>
    <div class="card-body">
      {% for name, source_value, translated_value in markdown_fields %}
      <div class="mb-2">
        <div class="form-text">{{ _("Source") }} — {{ name }}</div>
        <div class="border rounded p-2 mb-2 admin-source-text">{{ source_value }}</div>
        {{ textarea_field("md_" ~ name, _("%(name)s translation") | format(name=name), translated_value, rows=6, markdown=true) }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% if item_pairs %}
  <div class="card mb-3">
    <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Items") }}</h2></div>
    <div class="card-body p-0 table-responsive admin-table-wrap">
      <table class="table table-striped mb-0 admin-table">
        <thead>
          <tr>
            <th scope="col">{{ _("Source") }}</th>
            <th scope="col">{{ _("Translation") }} ({{ language.value | upper }})</th>
          </tr>
        </thead>
        <tbody>
          {% for source_row, translated_row in item_pairs %}
          {% for column in item_columns %}
          <tr>
            <td><span class="form-text">{{ column }}</span> {{ source_row[loop.index0] }}</td>
            <td><label class="mb-0 w-100">
              <span class="visually-hidden admin-visually-hidden">{{ column }}</span>
              <input class="form-control form-control-sm admin-input" name="item_{{ column }}"
                     value="{{ translated_row[loop.index0] }}"></label></td>
          </tr>
          {% endfor %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}
  <div class="card mb-3"><div class="card-body">
    {{ textarea_field("media", _("Media asset IDs (one per line)"), media_text, rows=3) }}
  </div></div>
  <button type="submit" class="btn btn-primary">{{ _("Save translation") }}</button>
</form>
{% else %}
<p class="admin-empty">{{ _("The source section has no fields yet — add them on the") }}
  <a href="/pages/{{ page.id }}/sections/{{ section.key }}">{{ _("section editor") }}</a> {{ _("first.") }}</p>
{% endif %}
{% endblock %}
