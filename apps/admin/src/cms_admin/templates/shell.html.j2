{# The authenticated chrome (ADR-0015): the ph7x design system natively —
   navy top bar, dark side navigation, editorial main column. Pages set
   `active_section` so the navigation marks the current page. #}
{% extends "base.html.j2" %}
{% block body %}
<a class="admin-skip" href="#main">Skip to content</a>
<header class="admin-topbar">
  <span class="admin-brand">Sardine CMS<span class="adm-sub">Admin</span></span>
  <span class="admin-topbar-spacer"></span>
  <span class="admin-user">
    <span>{{ user.username }}</span>
    <span class="admin-tag">{{ user.role.value }}</span>
  </span>
  <form method="post" action="/logout">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="admin-btn admin-btn-small">Sign out</button>
  </form>
</header>
<div class="admin-shell">
  <nav class="admin-nav" aria-label="Admin sections">
    <span class="admin-nav-label">Content</span>
    <ul>
      <li><a href="/" {% if active_section == "dashboard" %}aria-current="page"{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Dashboard</a></li>
      <li><a href="/articles" {% if active_section == "articles" %}aria-current="page"{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>Articles</a></li>
      <li><a href="/pages" {% if active_section == "pages" %}aria-current="page"{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 9v12"/></svg>Pages</a></li>
      <li><a href="/media" {% if active_section == "media" %}aria-current="page"{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="10" r="1.5"/><path d="M21 15l-5-5-9 9"/></svg>Media</a></li>
    </ul>
    <span class="admin-nav-label">Pipeline</span>
    <ul>
      <li><a href="/publishing" {% if active_section == "publishing" %}aria-current="page"{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>Publishing</a></li>
    </ul>
  </nav>
  <main id="main" class="admin-main">
    {% block content %}{% endblock %}
  </main>
</div>
{% endblock %}
