{# The authenticated chrome (ADR-0017): AdminLTE 4, vendored, used exactly
   as its reference pages do — navbar, dark sidebar with Bootstrap Icons,
   content header with breadcrumb, footer. The admin still ships zero
   JavaScript, so JS-only widgets (sidebar toggle, dropdowns, treeview)
   are simply not used. Pages set `active_section` so the sidebar and the
   breadcrumb mark the current page. #}
{% extends "base.html.j2" %}
{% set nav_items = [
  ("dashboard", "/", "Dashboard", "bi-speedometer"),
  ("articles", "/articles", "Articles", "bi-journal-text"),
  ("pages", "/pages", "Pages", "bi-file-earmark-text"),
  ("media", "/media", "Media", "bi-image"),
] %}
{% set section_labels = {
  "dashboard": "Dashboard", "articles": "Articles", "pages": "Pages",
  "media": "Media", "publishing": "Publishing",
} %}
{% block body %}
<a class="admin-skip" href="#main">Skip to content</a>
<div class="app-wrapper">
  <nav class="app-header navbar navbar-expand bg-body admin-topbar">
    <div class="container-fluid">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button" aria-label="Toggle sidebar">
            <i class="bi bi-list" aria-hidden="true"></i>
          </a>
        </li>
        <li class="nav-item d-none d-md-block">
          <a href="/" class="nav-link"><i class="bi bi-house me-1" aria-hidden="true"></i>Home</a>
        </li>
        <li class="nav-item d-none d-md-block">
          <a href="/preview/" class="nav-link"><i class="bi bi-eye me-1" aria-hidden="true"></i>Preview</a>
        </li>
      </ul>
      <ul class="navbar-nav ms-auto admin-user">
        <li class="nav-item">
          <a class="nav-link" href="#" data-lte-toggle="fullscreen" aria-label="Toggle fullscreen">
            <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
            <i data-lte-icon="minimize" class="bi bi-fullscreen-exit d-none"></i>
          </a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link" href="#" id="bd-theme" aria-label="Toggle color scheme"
             data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-sun-fill" data-lte-theme-icon="light"></i>
            <i class="bi bi-moon-fill d-none" data-lte-theme-icon="dark"></i>
            <i class="bi bi-circle-half d-none" data-lte-theme-icon="auto"></i>
          </a>
          <ul class="dropdown-menu dropdown-menu-end admin-theme-menu" aria-labelledby="bd-theme">
            <li>
              <button type="button" class="dropdown-item d-flex align-items-center"
                      data-bs-theme-value="light" aria-pressed="false">
                <i class="bi bi-sun-fill me-2"></i>
                Light
                <i class="bi bi-check-lg ms-auto d-none"></i>
              </button>
            </li>
            <li>
              <button type="button" class="dropdown-item d-flex align-items-center"
                      data-bs-theme-value="dark" aria-pressed="false">
                <i class="bi bi-moon-fill me-2"></i>
                Dark
                <i class="bi bi-check-lg ms-auto d-none"></i>
              </button>
            </li>
            <li>
              <button type="button" class="dropdown-item d-flex align-items-center active"
                      data-bs-theme-value="auto" aria-pressed="true">
                <i class="bi bi-circle-half me-2"></i>
                Auto
                <i class="bi bi-check-lg ms-auto d-none"></i>
              </button>
            </li>
          </ul>
        </li>
        <li class="nav-item dropdown user-menu">
          <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
            <svg class="user-image rounded-circle shadow" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="32" fill="#0e1626"/><g transform="translate(32 32) rotate(-38)"><ellipse rx="17" ry="7" fill="none" stroke="#d8cfc0" stroke-width="2.5"/><path fill="#d8cfc0" d="M-17 0 Q-21 -3.5 -24 -5 Q-22 -1.8 -22 0 Q-22 1.8 -24 5 Q-21 3.5 -17 0Z"/><circle cx="12" cy="-1.5" r="1.6" fill="#0e1626" stroke="#d8cfc0" stroke-width="1.4"/></g></svg>
            <span class="d-none d-md-inline">{{ user.username }}</span>
          </a>
          <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
            <li class="user-header text-bg-primary">
              <svg class="rounded-circle shadow" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="32" fill="#0e1626"/><g transform="translate(32 32) rotate(-38)"><ellipse rx="17" ry="7" fill="none" stroke="#d8cfc0" stroke-width="2.5"/><path fill="#d8cfc0" d="M-17 0 Q-21 -3.5 -24 -5 Q-22 -1.8 -22 0 Q-22 1.8 -24 5 Q-21 3.5 -17 0Z"/><circle cx="12" cy="-1.5" r="1.6" fill="#0e1626" stroke="#d8cfc0" stroke-width="1.4"/></g></svg>
              <p>
                {{ user.username }} - {{ user.role.value }}
                <small>Sardine CMS admin</small>
              </p>
            </li>
            <li class="user-footer">
              <form method="post" action="/logout" class="mb-0 float-end">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-outline-danger">Sign out</button>
              </form>
            </li>
          </ul>
        </li>
      </ul>
    </div>
  </nav>
  <aside class="app-sidebar bg-body-secondary shadow admin-nav" data-bs-theme="dark">
    <div class="sidebar-brand">
      <a href="/" class="brand-link">
        <svg class="brand-image opacity-75 shadow" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#0e1626"/><g transform="translate(32 32) rotate(-38)"><ellipse rx="17" ry="7" fill="none" stroke="#d8cfc0" stroke-width="2.5"/><path fill="#d8cfc0" d="M-17 0 Q-21 -3.5 -24 -5 Q-22 -1.8 -22 0 Q-22 1.8 -24 5 Q-21 3.5 -17 0Z"/><circle cx="12" cy="-1.5" r="1.6" fill="#0e1626" stroke="#d8cfc0" stroke-width="1.4"/></g></svg>
        <span class="brand-text fw-light">Sardine CMS</span>
      </a>
    </div>
    <div class="sidebar-wrapper">
      <nav aria-label="Admin sections">
        <ul class="nav sidebar-menu flex-column">
          {% for section, url, label, icon in nav_items %}
          <li class="nav-item">
            <a href="{{ url }}" class="nav-link{% if active_section == section %} active{% endif %}"
               {% if active_section == section %}aria-current="page"{% endif %}>
              <i class="nav-icon bi {{ icon }}" aria-hidden="true"></i>
              <p>{{ label }}</p>
            </a>
          </li>
          {% endfor %}
          <li class="nav-header">PIPELINE</li>
          <li class="nav-item">
            <a href="/publishing" class="nav-link{% if active_section == "publishing" %} active{% endif %}"
               {% if active_section == "publishing" %}aria-current="page"{% endif %}>
              <i class="nav-icon bi bi-rocket-takeoff" aria-hidden="true"></i>
              <p>Publishing</p>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </aside>
  <main class="app-main" id="main">
    <div class="app-content-header">
      <div class="container-fluid">
        <div class="row">
          <div class="col-sm-6">
            {% block header %}{% endblock %}
          </div>
          <div class="col-sm-6">
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ section_labels.get(active_section, "Admin") }}</li>
              </ol>
            </nav>
          </div>
        </div>
      </div>
    </div>
    <div class="app-content">
      <div class="container-fluid">
        {% block content %}{% endblock %}
      </div>
    </div>
  </main>
  <footer class="app-footer">
    <div class="float-end d-none d-sm-inline">Static-first, multilingual</div>
    <strong>Copyright &copy; 2026
      <a href="https://sardine.ph7x.com" class="text-decoration-none">Sardine CMS</a>.</strong>
    Apache-2.0.
  </footer>
</div>
{% endblock %}
