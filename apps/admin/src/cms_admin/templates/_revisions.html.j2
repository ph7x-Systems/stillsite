{# Revision history card (ADR-0025). Context: revisions (list of
   (number, when, author)), base_url of the entity. #}
<div class="card mb-3">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Revisions") }}</h2></div>
  {% if revisions %}
  <div class="card-body p-0 table-responsive admin-table-wrap">
    <table class="table table-sm table-striped mb-0 admin-table admin-revisions-table">
      <thead><tr><th scope="col">#</th><th scope="col">{{ _("When") }}</th><th scope="col">{{ _("Author") }}</th><th scope="col"></th></tr></thead>
      <tbody>
        {% for number, when, author in revisions %}
        <tr>
          <th scope="row">{{ number }}</th>
          <td>{{ when.strftime("%Y-%m-%d %H:%M") }} UTC</td>
          <td>{{ author }}</td>
          <td><a href="{{ base_url }}/revisions/{{ number }}">{{ _("View and restore") }}</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="card-footer form-text">{{ _("Every save keeps a snapshot (the newest %(limit)s); restoring saves a new revision, so it is always undoable.") | format(limit=20) }}</div>
  {% else %}
  <div class="card-body"><p class="admin-empty mb-0">{{ _("No revisions yet — they appear after the first save.") }}</p></div>
  {% endif %}
</div>
