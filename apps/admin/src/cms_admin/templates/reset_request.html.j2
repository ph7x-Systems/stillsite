{% extends "base.html.j2" %}
{% block title %}{{ _("Reset your password") }} — Sardine CMS admin{% endblock %}
{% block bodyclass %}login-page bg-body-secondary{% endblock %}
{% block body %}
<main id="main" class="login-box">
  <div class="card card-outline card-primary admin-login">
    <div class="card-header text-center">
      <img src="/static/brand/sardine.svg" alt="" width="56" height="56" class="mb-2">
      <span class="h4 d-block">Sardine CMS <small class="text-body-secondary">admin</small></span>
    </div>
    <div class="card-body">
      <h1 class="login-box-msg h5">{{ _("Reset your password") }}</h1>
      {% if sent %}
      <p role="status" class="alert alert-success admin-alert">{{ _("If that account has an address, a message is on its way.") }}</p>
      {% else %}
      <form method="post" action="/reset">
        <input type="hidden" name="login_csrf" value="{{ login_csrf }}">
        <div class="mb-3 admin-field">
          <label class="form-label" for="username">{{ _("Username") }}</label>
          <input class="form-control admin-input" id="username" name="username" type="text"
                 autocomplete="username" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">{{ _("Send the reset link") }}</button>
      </form>
      {% endif %}
      <p class="mt-3 mb-0 text-center"><a href="/login">{{ _("Back to sign in") }}</a></p>
    </div>
  </div>
</main>
{% endblock %}
