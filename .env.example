# Sardine CMS — admin panel environment example
# Copy to .env (or export in your process manager) and adjust.
# NEVER commit a real .env. Site identity, languages, theme, forms and
# deployment live in sardine.toml, not here.

# Storage (SQLite by default; PostgreSQL/MySQL/MSSQL URLs also work)
SARDINE_STORAGE_URL=sqlite:///content.db

# Project directory holding sardine.toml (panel builds and deploys)
SARDINE_PROJECT_DIR=.

# Sessions and cookies
SARDINE_ADMIN_SESSION_HOURS=12
# Set to 0 only for plain-http local development
SARDINE_ADMIN_COOKIE_SECURE=1

# Media uploads
SARDINE_MEDIA_DIR=media
SARDINE_ADMIN_UPLOAD_MAX_MB=10
SARDINE_ADMIN_UPLOAD_MAX_PIXELS=40000000

# Publishing
# Set to 0 to allow publishing despite validation errors
SARDINE_ADMIN_PUBLISH_GATE=1

# Audit trail retention (days; 0 keeps everything)
SARDINE_ACTIVITY_RETENTION_DAYS=365

# E-mail (password reset, notifications, form submissions)
# SARDINE_MAIL_TRANSPORT=smtp
# SARDINE_SMTP_URL=smtps://user:password@smtp.example.com:465
# SARDINE_MAIL_FROM=cms@example.com

# Azure Static Web Apps deployment token (read at deploy time only)
# SARDINE_SWA_DEPLOY_TOKEN=
