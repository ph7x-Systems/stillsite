# Stillsite — local configuration example
# Copy to .env and adjust. NEVER commit the real .env.

# Database (SQLite in dev; PostgreSQL in production)
CMS_DATABASE_URL=sqlite:///./cms-dev.sqlite3
# CMS_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ph7x_cms

# Admin panel
CMS_ADMIN_HOST=127.0.0.1
CMS_ADMIN_PORT=8000
CMS_SECRET_KEY=change-me-generate-a-real-random-value
CMS_SESSION_LIFETIME_MINUTES=60

# Languages (EN is always the source)
CMS_LANGUAGES=en,pt-pt,es,fr,de
CMS_SOURCE_LANGUAGE=en

# Build / export
CMS_EXPORT_DIR=./export
CMS_BASE_URL=http://localhost:8080

# Media
CMS_MEDIA_MAX_UPLOAD_MB=10
